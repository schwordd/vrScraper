@using vrScraper.DB.Models

<div class="video-item">
    <div class="thumbnail-container @(Item.IsThumbnailNotAvailable == true ? "not-available" : "")"
         @onclick="OnThumbnailClick">
        @{
            if (string.IsNullOrEmpty(Item.Thumbnail))
            {
                Item.IsThumbnailNotAvailable = true;
            }
        }
        <img src="@(string.IsNullOrEmpty(Item.Thumbnail) ? "/images/thumbnail-not-available.svg" : Item.Thumbnail)"
             alt="@Item.Title"
             @onerror="HandleImageError" />
        @if (Item.IsThumbnailNotAvailable != true)
        {
            <div class="play-overlay">
                <i class="icon-play-circle"></i>
            </div>
        }
        <div class="duration-badge">@FormatDuration(Item.Duration)</div>
        <div class="thumbnail-overlay">
            <button class="btn btn-danger btn-sm delete-btn" @onclick:stopPropagation="true" @onclick="() => OnDelete.InvokeAsync(Item.Id)" title="Delete video">
                <i class="icon-trash-2"></i>
            </button>
            <button class="btn btn-info btn-sm similar-btn" @onclick:stopPropagation="true" @onclick="() => OnShowSimilar.InvokeAsync(Item)" title="Find similar videos">
                <i class="icon-sparkles"></i>
            </button>
            <button class="btn btn-primary btn-sm download-btn" @onclick:stopPropagation="true" @onclick="() => OnDownload.InvokeAsync(Item)" title="Download video">
                <i class="icon-download"></i>
            </button>
        </div>
        <div class="like-btn-container">
            <button class="like-btn @(Item.Liked ? "liked" : "not-liked")"
                    @onclick:stopPropagation="true"
                    @onclick="() => OnToggleLike.InvokeAsync(Item)"
                    title="@(Item.Liked ? "Remove from favorites" : "Add to favorites")">
                <i class="icon-heart"></i>
            </button>
            <span class="play-count" title="Times played">
                <i class="icon-play"></i>
                @Item.PlayCount
            </span>
        </div>
        <div class="watchlist-btn-container @(SelectedWatchlistId > 0 ? "visible" : "")">
            <button class="watchlist-btn @(IsInWatchlist ? "in-watchlist" : "not-in-watchlist")"
                    @onclick:stopPropagation="true"
                    @onclick="() => OnToggleWatchlist.InvokeAsync(Item.Id)"
                    title="@(IsInWatchlist ? "Remove from watchlist" : "Add to watchlist")">
                <i class="icon-bookmark"></i>
            </button>
        </div>
    </div>
    <h3 title="@(!string.IsNullOrEmpty(Item.NormalizedTitle) && Item.NormalizedTitle != Item.Title ? Item.Title : "")">@if (!string.IsNullOrEmpty(Item.NormalizedTitle) && Item.NormalizedTitle != Item.Title) { <i class="icon-sparkles ai-icon"></i> }@(Item.NormalizedTitle ?? Item.Title)</h3>
    @if (Item.Stars != null && Item.Stars.Any())
    {
        <div class="star-container">
            @foreach (var starInfo in Item.Stars)
            {
                var isAutoStar = IsAutoDetectedStar(Item, starInfo.Id);
                <button type="button" class="btn btn-primary star-pill @(isAutoStar ? "auto-detected" : "")" @onclick="() => OnAddStarFilter.InvokeAsync(starInfo.Name)">
                    @if (isAutoStar) { <i class="icon-sparkles"></i> }
                    <i class="icon-user"></i> @starInfo.Name
                </button>
            }
        </div>
    }
    <div class="tag-container">
        @if (Item.Tags != null)
        {
            @foreach (var tagInfo in Item.Tags)
            {
                var isAutoTag = IsAutoDetectedTag(Item, tagInfo.Id);
                <button type="button" class="btn btn-primary tag-pill @(isAutoTag ? "auto-detected" : "")" @onclick="() => OnAddTagFilter.InvokeAsync(tagInfo.Name)">
                    @if (isAutoTag) { <i class="icon-sparkles"></i> }@tagInfo.Name
                </button>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DbVideoItem Item { get; set; } = default!;
    [Parameter] public long SelectedWatchlistId { get; set; }
    [Parameter] public bool IsInWatchlist { get; set; }

    [Parameter] public EventCallback<DbVideoItem> OnPlay { get; set; }
    [Parameter] public EventCallback<long> OnDelete { get; set; }
    [Parameter] public EventCallback<DbVideoItem> OnShowSimilar { get; set; }
    [Parameter] public EventCallback<DbVideoItem> OnDownload { get; set; }
    [Parameter] public EventCallback<DbVideoItem> OnToggleLike { get; set; }
    [Parameter] public EventCallback<long> OnToggleWatchlist { get; set; }
    [Parameter] public EventCallback<string> OnAddStarFilter { get; set; }
    [Parameter] public EventCallback<string> OnAddTagFilter { get; set; }
    [Parameter] public EventCallback<(Microsoft.AspNetCore.Components.Web.ErrorEventArgs Error, DbVideoItem Item)> OnImageError { get; set; }

    private async Task OnThumbnailClick()
    {
        if (Item.IsThumbnailNotAvailable != true)
            await OnPlay.InvokeAsync(Item);
    }

    private async Task HandleImageError(Microsoft.AspNetCore.Components.Web.ErrorEventArgs e)
    {
        await OnImageError.InvokeAsync((e, Item));
    }

    private static bool IsAutoDetectedStar(DbVideoItem video, long starId)
    {
        return video.VideoStars?.Any(vs => vs.StarId == starId && vs.IsAutoDetected) ?? false;
    }

    private static bool IsAutoDetectedTag(DbVideoItem video, long tagId)
    {
        return video.VideoTags?.Any(vt => vt.TagId == tagId && vt.IsAutoDetected) ?? false;
    }

    private static string FormatDuration(TimeSpan d)
    {
        return d.TotalHours >= 1 ? $"{(int)d.TotalHours}:{d.Minutes:D2}:{d.Seconds:D2}" : $"{d.Minutes}:{d.Seconds:D2}";
    }
}
