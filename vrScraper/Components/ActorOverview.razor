@using vrScraper.DB.Models
@using vrScraper.Services
@inject IVideoService Videos

<CollapsibleItemList Title="Actresses"
                     Items="@items"
                     PillClass="item-pill item-pill-actor" />

@code {
    private List<(string Name, long Count)> items = new();

    protected override async Task OnInitializedAsync()
    {
        var starInfos = await Videos.GetActorInfos();
        items = starInfos.Select(s => (s.Star.Name, s.Count)).ToList();
    }
}
