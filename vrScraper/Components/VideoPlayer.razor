@using Microsoft.EntityFrameworkCore
@using vrScraper.DB
@using vrScraper.DB.Models
@using vrScraper.Services
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject IScraperRegistry scraperRegistry
@inject VrScraperContext context

<div class="video-player-overlay @(_isVisible ? "visible" : "")" @onclick="ClosePlayer">
    <div class="video-player-container" @onclick:stopPropagation>
        <div class="close-button" @onclick="ClosePlayer" title="Close (Esc)">
            <i class="icon-x"></i>
        </div>

        @if (HasPrevious)
        {
            <button class="nav-button nav-prev" @onclick="NavigatePrevious" title="Previous video (P)">
                <i class="icon-chevron-left"></i>
            </button>
        }

        @if (HasNext)
        {
            <button class="nav-button nav-next" @onclick="NavigateNext" title="Next video (N)">
                <i class="icon-chevron-right"></i>
            </button>
        }

        @if (_isLoading)
        {
            <div class="loading-indicator">
                <div class="spinner-border text-light" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <div class="mt-2 text-light">Loading video...</div>
            </div>
        }

        @if (_errorMessage != null)
        {
            <div class="error-message">
                <i class="icon-triangle-alert text-warning"></i>
                <div>@_errorMessage</div>
                <button class="btn btn-sm btn-light mt-3" @onclick="ClosePlayer">Close</button>
            </div>
        }

        <div class="video-container @(_isLoading || _errorMessage != null ? "d-none" : "")">
            <video id="vr-video" class="video-js vjs-big-play-centered"></video>
        </div>

        @if (_isVisible && !_isLoading && _errorMessage == null)
        {
            <div class="player-toolbar">
                <button class="like-btn @(CurrentVideo?.Liked == true ? "liked" : "not-liked") @(_feedbackTarget == "like" ? "pulse" : "")"
                        @key="@($"like-{_feedbackKey}")"
                        @onclick="ClickToggleLike" title="Like (L)">
                    <i class="icon-heart"></i>
                </button>

                @if (SelectedWatchlistId > 0)
                {
                    <button class="watchlist-btn @(IsInWatchlist ? "in-watchlist" : "not-in-watchlist") @(_feedbackTarget == "watchlist" ? "pulse" : "")"
                            @key="@($"wl-{_feedbackKey}")"
                            @onclick="ClickToggleWatchlist" title="Watchlist (B)">
                        <i class="icon-bookmark"></i>
                    </button>
                }

                <span class="video-counter">@(VideoIndex + 1) / @VideoListCount</span>

                <button class="help-btn @(_shortcutsPinned ? "active" : "")" @onclick="ToggleShortcutsPinned" title="Shortcuts (H)">
                    <i class="icon-help-circle"></i>
                </button>
            </div>
        }

        @if (_showShortcutsOverlay)
        {
            <div class="shortcuts-overlay @(_shortcutsPinned ? "pinned" : "")" @key="_shortcutsKey">
                <div class="shortcuts-content">
                    <div class="shortcuts-grid">
                        <span class="shortcut-key">← →</span><span>±5s</span>
                        <span class="shortcut-key">Ctrl+← →</span><span>±30s</span>
                        <span class="shortcut-key">↑ ↓</span><span>Vol</span>
                        <span class="shortcut-key">Space</span><span>Play/Pause</span>
                        <span class="shortcut-key">M</span><span>Mute</span>
                        <span class="shortcut-key">F</span><span>Fullscreen</span>
                        <span class="shortcut-key">N / P</span><span>Next / Prev</span>
                        <span class="shortcut-key">L</span><span>Like</span>
                        <span class="shortcut-key">B</span><span>Bookmark</span>
                        <span class="shortcut-key">Scroll</span><span>Zoom</span>
                        <span class="shortcut-key">H</span><span>Help</span>
                        <span class="shortcut-key">Esc</span><span>Close</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public DbVideoItem? CurrentVideo { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public bool HasNext { get; set; }

    [Parameter]
    public bool HasPrevious { get; set; }

    [Parameter]
    public int VideoIndex { get; set; }

    [Parameter]
    public int VideoListCount { get; set; }

    [Parameter]
    public long SelectedWatchlistId { get; set; }

    [Parameter]
    public bool IsInWatchlist { get; set; }

    [Parameter]
    public EventCallback OnNavigateNext { get; set; }

    [Parameter]
    public EventCallback OnNavigatePrevious { get; set; }

    [Parameter]
    public EventCallback<DbVideoItem> OnToggleLike { get; set; }

    [Parameter]
    public EventCallback<long> OnToggleWatchlist { get; set; }

    private bool _isVisible = false;
    private bool _isLoading = false;
    private bool _isNavigating = false;
    private string? _errorMessage = null;
    private VideoSource? _videoSource;
    private string? _videoType = "180";
    private long? _videoId = null;
    private DotNetObjectReference<VideoPlayer>? _dotNetRef;
    private bool _showShortcutsOverlay = false;
    private bool _shortcutsPinned = false;
    private int _shortcutsKey = 0;
    private string? _feedbackTarget = null;
    private int _feedbackKey = 0;

    protected override async Task OnInitializedAsync()
    {
        // Erstellen der .NET-Objektreferenz für JS-Callbacks beim Start
        _dotNetRef = DotNetObjectReference.Create(this);
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Registriere die Callback-Referenz
            await JSRuntime.InvokeVoidAsync("registerPlayerErrorCallback", _dotNetRef);
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    public async Task ShowVideo(DbVideoItem video)
    {
        try
        {
            // Setze Zustand zurück
            _errorMessage = null;
            _isLoading = true;
            _isNavigating = false;
            this.CurrentVideo = video;
            _videoId = video.Id;

            // Element sichtbar machen + Shortcuts-Overlay anzeigen
            _isVisible = true;
            _showShortcutsOverlay = true;
            _shortcutsPinned = false;
            _shortcutsKey++;
            StateHasChanged();

            // Flag sofort setzen damit Page-Keyboard-Handler blockiert wird
            await JSRuntime.InvokeVoidAsync("setPlayerOpen", true);

            // Video-Quelle abrufen
            var foundVideo = await context.VideoItems
                .Include(v => v.Tags)
                .Include(v => v.Stars)
                .FirstOrDefaultAsync(v => v.Id == video.Id);

            if (foundVideo == null)
            {
                _errorMessage = "Video not found.";
                _isLoading = false;
                StateHasChanged();
                return;
            }

            var scraper = scraperRegistry.GetScraperForSite(foundVideo.Site);
            if (scraper == null)
            {
                _errorMessage = "No scraper for this site";
                _isLoading = false;
                StateHasChanged();
                return;
            }
            _videoSource = await scraper.GetSource(foundVideo, context);
            if (_videoSource == null)
            {
                _errorMessage = "Video source not available.";
                _isLoading = false;
                StateHasChanged();
                return;
            }

            // Bestimme Videotyp basierend auf Tags
            DetermineVideoType(foundVideo);

            // VideoJS initialisieren mit der gewünschten Quelle und Konfiguration
            _isLoading = false;
            StateHasChanged();

            // Verzögerung, um sicherzustellen, dass DOM aktualisiert wurde
            await Task.Delay(200);
            await InitializeVideoJS();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading video: {ex.Message}";
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void DetermineVideoType(DbVideoItem video)
    {
        // Bestimme VR-Typ anhand der Tags
        if (video.Tags.Any(t => t.Name.Contains("360")))
        {
            _videoType = "360";
        }
        else if (video.Tags.Any(t => t.Name.Contains("180")))
        {
            _videoType = "180";
        }
        else
        {
            // Standard ist 180, falls nicht genauer spezifiziert
            _videoType = "180";
        }
    }

    private async Task InitializeVideoJS()
    {
        if (_videoSource == null || CurrentVideo == null) return;

        try
        {
            // Registriere die Callback-Referenz erneut vor der Player-Initialisierung
            await JSRuntime.InvokeVoidAsync("registerPlayerErrorCallback", _dotNetRef);

            await JSRuntime.InvokeVoidAsync("initializeVRPlayer",
                "vr-video",
                _videoSource.Src,
                _videoSource.Type,
                CurrentVideo.Title,
                _videoType,
                _videoId);  // Übergebe die Video-ID für Proxy-Zugriff
        }
        catch (Exception ex)
        {
            _errorMessage = $"Player initialization error: {ex.Message}";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnPlayerError(string errorMessage)
    {
        _errorMessage = $"Playback error: {errorMessage}";
        StateHasChanged();
    }

    [JSInvokable]
    public void OnFullscreenExit()
    {
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnKeyboardNext()
    {
        if (_isNavigating || !HasNext) return;
        _isNavigating = true;
        await OnNavigateNext.InvokeAsync();
    }

    [JSInvokable]
    public async Task OnKeyboardPrevious()
    {
        if (_isNavigating || !HasPrevious) return;
        _isNavigating = true;
        await OnNavigatePrevious.InvokeAsync();
    }

    [JSInvokable]
    public async Task OnKeyboardToggleLike()
    {
        if (CurrentVideo != null)
        {
            await OnToggleLike.InvokeAsync(CurrentVideo);
            _feedbackTarget = "like";
            _feedbackKey++;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnKeyboardToggleWatchlist()
    {
        if (CurrentVideo != null && SelectedWatchlistId > 0)
        {
            await OnToggleWatchlist.InvokeAsync(CurrentVideo.Id);
            _feedbackTarget = "watchlist";
            _feedbackKey++;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnKeyboardClose()
    {
        await ClosePlayer();
    }

    [JSInvokable]
    public void OnKeyboardToggleHelp()
    {
        ToggleShortcutsPinned();
    }

    private void ToggleShortcutsPinned()
    {
        if (_showShortcutsOverlay)
        {
            _shortcutsPinned = false;
            _showShortcutsOverlay = false;
        }
        else
        {
            _shortcutsPinned = true;
            _showShortcutsOverlay = true;
            _shortcutsKey++;
        }
        StateHasChanged();
    }

    private async Task NavigateNext()
    {
        if (_isNavigating || !HasNext) return;
        _isNavigating = true;
        await OnNavigateNext.InvokeAsync();
    }

    private async Task NavigatePrevious()
    {
        if (_isNavigating || !HasPrevious) return;
        _isNavigating = true;
        await OnNavigatePrevious.InvokeAsync();
    }

    private async Task ClickToggleLike()
    {
        if (CurrentVideo != null)
        {
            await OnToggleLike.InvokeAsync(CurrentVideo);
            _feedbackTarget = "like";
            _feedbackKey++;
            StateHasChanged();
        }
    }

    private async Task ClickToggleWatchlist()
    {
        if (CurrentVideo != null && SelectedWatchlistId > 0)
        {
            await OnToggleWatchlist.InvokeAsync(CurrentVideo.Id);
            _feedbackTarget = "watchlist";
            _feedbackKey++;
            StateHasChanged();
        }
    }

    private async Task ClosePlayer()
    {
        // VideoJS-Player beenden
        try
        {
            await JSRuntime.InvokeVoidAsync("disposeVRPlayer");
        }
        catch (Exception)
        {
            // Ignoriere Fehler beim Beenden des Players
        }

        _isVisible = false;
        _isLoading = false;
        _isNavigating = false;
        _errorMessage = null;
        _videoId = null;
        _showShortcutsOverlay = false;
        _shortcutsPinned = false;
        StateHasChanged();

        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            // VideoJS-Player beenden, falls noch nicht geschehen
            await JSRuntime.InvokeVoidAsync("disposeVRPlayer");

            // DotNetObjectReference freigeben
            _dotNetRef?.Dispose();
        }
        catch
        {
            // Fehler beim Disposal ignorieren
        }
    }
}
