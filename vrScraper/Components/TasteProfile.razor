@using vrScraper.DB.Models
@using vrScraper.Services
@inject IVideoService VideoService
@inject IRecommendationService RecommendationService

<div class="taste-columns">
    <div class="taste-col">
        <h6 class="taste-col-title">Top Tags</h6>
        @if (_topTags.Count == 0)
        {
            <p class="text-muted">No data yet</p>
        }
        else
        {
            @foreach (var t in _topTags)
            {
                <div class="taste-bar-row">
                    <span class="taste-label" title="@t.Name">
                        @t.Name
                        <a href="/videos?tags=@Uri.EscapeDataString(t.Name)" class="taste-link" title="Show videos tagged @t.Name">
                            <i class="icon-external-link"></i>
                        </a>
                    </span>
                    <div class="taste-bar-track">
                        <div class="taste-bar-fill taste-bar-tag" style="width: @(t.Pct.ToString("F0"))%"></div>
                    </div>
                    <div class="taste-stats">
                        <span title="Videos">@t.Videos</span>
                        <span title="Watched" class="stat-watched">@t.Watched</span>
                        <span title="Liked" class="stat-liked">@t.Liked</span>
                        <span title="Like Rate">@(t.LikeRate.ToString("F0"))%</span>
                    </div>
                </div>
            }
        }
    </div>
    <div class="taste-col">
        <h6 class="taste-col-title">Top Actresses</h6>
        @if (_topStars.Count == 0)
        {
            <p class="text-muted">No data yet</p>
        }
        else
        {
            @foreach (var s in _topStars)
            {
                <div class="taste-bar-row">
                    <span class="taste-label" title="@s.Name">
                        @s.Name
                        <a href="/videos?actresses=@Uri.EscapeDataString(s.Name)" class="taste-link" title="Show videos for @s.Name">
                            <i class="icon-external-link"></i>
                        </a>
                    </span>
                    <div class="taste-bar-track">
                        <div class="taste-bar-fill taste-bar-star" style="width: @(s.Pct.ToString("F0"))%"></div>
                    </div>
                    <div class="taste-stats">
                        <span title="Videos">@s.Videos</span>
                        <span title="Watched" class="stat-watched">@s.Watched</span>
                        <span title="Liked" class="stat-liked">@s.Liked</span>
                        <span title="Watch Time">@FormatTime(s.WatchTime)</span>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private record TagRow(string Name, double Pct, int Videos, int Watched, int Liked, double LikeRate);
    private record StarRow(string Name, double Pct, int Videos, int Watched, int Liked, TimeSpan WatchTime);

    private List<TagRow> _topTags = new();
    private List<StarRow> _topStars = new();

    protected override async Task OnInitializedAsync()
    {
        var videos = await VideoService.GetVideoItems();
        var totalVideoCount = videos.Count;

        // Build tag stats — ranked by like count, exclude ubiquitous tags (>30%)
        var tagGroups = videos
            .SelectMany(v => v.Tags.Select(t => new { Tag = t.Name, Video = v }))
            .GroupBy(x => x.Tag, StringComparer.OrdinalIgnoreCase)
            .Where(g => (double)g.Count() / totalVideoCount <= 0.3)
            .Select(g =>
            {
                var tagVideos = g.Select(x => x.Video).ToList();
                var liked = tagVideos.Count(v => v.Liked);
                var watched = tagVideos.Count(v => v.PlayCount > 0);
                var likeRate = tagVideos.Count > 0 ? (double)liked / tagVideos.Count * 100 : 0;
                return new { Name = g.Key, Videos = tagVideos.Count, Watched = watched, Liked = liked, LikeRate = likeRate };
            })
            .Where(t => t.Liked > 0)
            .OrderByDescending(t => t.Liked)
            .Take(10)
            .ToList();

        var tagMaxLikes = tagGroups.Any() ? tagGroups.Max(t => t.Liked) : 1;
        _topTags = tagGroups
            .Select(t => new TagRow(t.Name, (double)t.Liked / tagMaxLikes * 100, t.Videos, t.Watched, t.Liked, t.LikeRate))
            .ToList();

        // Build star stats — ranked by like count
        var starGroups = videos
            .SelectMany(v => v.Stars.Select(s => new { Star = s.Name, Video = v }))
            .GroupBy(x => x.Star, StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var starVideos = g.Select(x => x.Video).ToList();
                var liked = starVideos.Count(v => v.Liked);
                var watched = starVideos.Count(v => v.PlayCount > 0);
                var watchTime = TimeSpan.FromTicks(starVideos.Sum(v => v.PlayDurationEst.Ticks));
                return new { Name = g.Key, Videos = starVideos.Count, Watched = watched, Liked = liked, WatchTime = watchTime };
            })
            .Where(s => s.Liked > 0)
            .OrderByDescending(s => s.Liked)
            .Take(10)
            .ToList();

        var starMaxLikes = starGroups.Any() ? starGroups.Max(s => s.Liked) : 1;
        _topStars = starGroups
            .Select(s => new StarRow(s.Name, (double)s.Liked / starMaxLikes * 100, s.Videos, s.Watched, s.Liked, s.WatchTime))
            .ToList();
    }

    private static string FormatTime(TimeSpan t)
    {
        if (t.TotalHours >= 1) return $"{(int)t.TotalHours}h";
        if (t.TotalMinutes >= 1) return $"{(int)t.TotalMinutes}m";
        return "0m";
    }
}
