@for (int i = 0; i < Count; i++)
{
    <div class="skeleton-card">
        <div class="skeleton-thumbnail shimmer"></div>
        <div class="skeleton-title shimmer"></div>
        <div class="skeleton-tags shimmer"></div>
    </div>
}

@code {
    [Parameter] public int Count { get; set; } = 30;
}
