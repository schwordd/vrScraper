@using vrScraper.DB.Models
@using vrScraper.Services
@inject IVideoService Videos

<CollapsibleItemList Title="Tags"
                     Items="@items"
                     PillClass="tag-pill"
                     FilterParam="tags" />

@code {
    private List<(string Name, long Count)> items = new();

    protected override async Task OnInitializedAsync()
    {
        var tagInfos = await Videos.GetTagInfos();
        items = tagInfos.Select(t => (t.Tag.Name, t.Count)).ToList();
    }
}
