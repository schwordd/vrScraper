@using Microsoft.AspNetCore.Components

<div class="item-container">
    @if (Items != null)
    {
        @foreach (var item in Items)
        {
            @if (string.IsNullOrEmpty(FilterParam))
            {
                <span class="@PillClass">
                    @item.Name <span class="item-count">@item.Count</span>
                </span>
            }
            else
            {
                <a href="/videos?@FilterParam=@Uri.EscapeDataString(item.Name)" class="@PillClass">
                    @item.Name <span class="item-count">@item.Count</span>
                </a>
            }
        }
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<(string Name, long Count)> Items { get; set; } = new();
    [Parameter] public string PillClass { get; set; } = "tag-pill";
    [Parameter] public string FilterParam { get; set; } = "";
}
