@page "/videos"

@using Newtonsoft.Json
@using vrScraper.DB.Models
@using vrScraper.Services
@using vrScraper.Components

@inject IVideoService VideoService
@inject ISettingService SettingService
@inject ITabService TabService
@inject IJSRuntime JSRuntime
@inject IServiceProvider serviceProvider
@inject IRecommendationService RecommendationService
@inject IScraperRegistry ScraperRegistry
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<div class="main-container">

    <div class="filters">
        <div class="filter-row">
            <span class="filter-item">
                <div class="search-wrapper">
                    <i class="icon-search search-icon"></i>
                    <input type="text" class="form-control filter-search" id="search"
                           placeholder="Search title..."
                           @bind="SearchQuery"
                           @bind:event="oninput" />
                </div>
            </span>

            <span class="filter-item">
                <select class="form-select filter-select" @bind="CurrentSortOption">
                    <option value="latest">Latest</option>
                    <option value="rating">Rating</option>
                    <option value="random">Random</option>
                    <option value="playtime">Most played time</option>
                    <option value="playcount">Most played count</option>
                    <option value="recentlywatched">Recently watched</option>
                    <option value="bestunwatched">Best unwatched</option>
                    <option value="recommended">Recommended</option>
                </select>
            </span>

            <span class="filter-item">
                <input class="form-check-input" type="checkbox" @bind="ShowOnlyLiked" id="showLikedCheck">
                <label class="form-check-label" for="showLikedCheck">Liked</label>
            </span>

            <span class="filter-item">
                <input class="form-check-input" type="checkbox" @bind="ShowOnlyUnwatched" id="showUnwatchedCheck">
                <label class="form-check-label" for="showUnwatchedCheck">Unwatched</label>
            </span>

            <span class="filter-item">
                <input class="form-check-input" type="checkbox" @bind="ShowOnlyWithErrors" id="showErrorsCheck">
                <label class="form-check-label" for="showErrorsCheck">Errors</label>
            </span>

            <span class="filter-item-count">@TotalItems videos</span>
        </div>

        <div class="filter-row">
            <span class="filter-item">
                <label>Tags:</label>
                <div class="d-flex align-items-center gap-2">
                    <MultiSelect IsMultiple="true"
                                    TItem="(DbTag Tag, long Count)"
                                    Data="@SortedTags"
                                    TextField="@((item) => $"{item.Tag.Name} ({item.Count})")"
                                    ValueField="@((item) => item.Tag.Name)"
                                    ShowSearch="true"
                                    @bind-SelectedValues="@SelectedTagValues" />
                    <button class="btn btn-sm btn-clear" @onclick="ClearTags" disabled="@(SelectedTags.Count == 0)" title="Clear tags">
                        <i class="icon-x"></i>
                    </button>
                </div>
            </span>

            <span class="filter-item">
                <label>Actresses:</label>
                <div class="d-flex align-items-center gap-2">
                    <MultiSelect IsMultiple="true"
                                    TItem="(DbStar Star, long Count)"
                                    Data="@SortedActresses"
                                    TextField="@((item) => $"{item.Star.Name} ({item.Count})")"
                                    ValueField="@((item) => item.Star.Name)"
                                    ShowSearch="true"
                                    @bind-SelectedValues="@SelectedActressesValues" />
                    <button class="btn btn-sm btn-clear" @onclick="ClearActresses" disabled="@(SelectedActresses.Count == 0)" title="Clear actresses">
                        <i class="icon-x"></i>
                    </button>
                </div>
            </span>

            @if (WatchlistTabs.Any())
            {
                <span class="filter-item">
                    <label><i class="icon-bookmark"></i> Watchlist:</label>
                    <MultiSelect TItem="DbVrTab"
                                    Data="@WatchlistTabs"
                                    TextField="@((item) => item.Name)"
                                    ValueField="@((item) => item.Id.ToString())"
                                    @bind-Value="@SelectedWatchlistValue" />
                    @if (_selectedWatchlistId > 0)
                    {
                        <button class="btn btn-sm @(_showOnlyWatchlist ? "btn-success" : "btn-outline-success")"
                                @onclick="() => ToggleShowOnlyWatchlist()"
                                title="Nur Watchlist-Videos anzeigen">
                            <i class="icon-filter"></i>
                        </button>
                    }
                </span>
            }

            @if (AvailableSites.Count > 1)
            {
                <span class="filter-item">
                    <label>Site:</label>
                    <div class="d-flex align-items-center gap-2">
                        <MultiSelect IsMultiple="true" TItem="string" Data="@AvailableSites"
                                        TextField="@((item) => item)" ValueField="@((item) => item)"
                                        @bind-SelectedValues="@SelectedSitesValues" />
                        <button class="btn btn-sm btn-clear" @onclick="ClearSites" disabled="@(_selectedSites.Count == 0)" title="Clear sites">
                            <i class="icon-x"></i>
                        </button>
                    </div>
                </span>
            }

            <span class="filter-item">
                <label>Duration:</label>
                <DualRangeSlider Min="0" Max="120" Step="5"
                                 @bind-MinValue="MinDurationMinutes"
                                 @bind-MaxValue="MaxDurationMinutes" />
            </span>
        </div>
    </div>

    <div class="content-wrapper">
        <Pager CurrentPage="CurrentPage" TotalPages="TotalPages" PageSize="PageSize"
               IsFirstPage="IsFirstPage" IsLastPage="IsLastPage"
               OnPageChanged="GoToPage" OnPageSizeChanged="PageSizeChanged" />

        @if (_isLoading)
        {
            <div class="video-gallery">
                <SkeletonCard Count="@PageSize" />
            </div>
        }
        else
        {
            <div class="video-gallery">
                @foreach (var item in PagedItems)
                {
                    <div class="video-item">
                        <div class="thumbnail-container @(item.IsThumbnailNotAvailable == true ? "not-available" : "")"
                             @onclick="(async () => { if (item.IsThumbnailNotAvailable != true) await PlayVideo(item); })">
                            @{
                                if (string.IsNullOrEmpty(item.Thumbnail))
                                {
                                    item.IsThumbnailNotAvailable = true;
                                }
                            }
                            <img src="@(string.IsNullOrEmpty(item.Thumbnail) ? "/images/thumbnail-not-available.svg" : item.Thumbnail)"
                                 alt="@item.Title"
                                 @onerror="e => HandleImageError(e, item)" />
                            @if (item.IsThumbnailNotAvailable != true)
                            {
                                <div class="play-overlay">
                                    <i class="icon-play-circle"></i>
                                </div>
                            }
                            <div class="duration-badge">@FormatDuration(item.Duration)</div>
                            <div class="thumbnail-overlay">
                                <button class="btn btn-danger btn-sm delete-btn" @onclick:stopPropagation="true" @onclick="() => DeleteVideo(item.Id)" title="Delete video">
                                    <i class="icon-trash-2"></i>
                                </button>
                                <button class="btn btn-info btn-sm similar-btn" @onclick:stopPropagation="true" @onclick="() => ShowSimilar(item)" title="Find similar videos">
                                    <i class="icon-sparkles"></i>
                                </button>
                                <button class="btn btn-primary btn-sm download-btn" @onclick:stopPropagation="true" @onclick="() => DownloadVideo(item)" title="Download video">
                                    <i class="icon-download"></i>
                                </button>
                            </div>
                            <div class="like-btn-container">
                                <button class="like-btn @(item.Liked ? "liked" : "not-liked")"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => ToggleLike(item)"
                                        title="@(item.Liked ? "Entfernen von Favoriten" : "Zu Favoriten hinzufügen")">
                                    <i class="icon-heart"></i>
                                </button>
                                <span class="play-count" title="Anzahl der Wiedergaben">
                                    <i class="icon-play"></i>
                                    @item.PlayCount
                                </span>
                            </div>
                            <div class="watchlist-btn-container @(_selectedWatchlistId > 0 ? "visible" : "")">
                                <button class="watchlist-btn @(IsInSelectedWatchlist(item.Id) ? "in-watchlist" : "not-in-watchlist")"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => ToggleWatchlist(item.Id)"
                                        title="@(IsInSelectedWatchlist(item.Id) ? "Aus Watchlist entfernen" : "Zur Watchlist hinzufügen")">
                                    <i class="icon-bookmark"></i>
                                </button>
                            </div>
                        </div>
                        <h3>@(item.NormalizedTitle ?? item.Title)</h3>
                        @if (!string.IsNullOrEmpty(item.NormalizedTitle) && item.NormalizedTitle != item.Title)
                        {
                            <div class="original-title">@item.Title</div>
                        }
                        @if (item.Stars != null && item.Stars.Any())
                        {
                            <div class="star-container">
                                @foreach (var starInfo in item.Stars)
                                {
                                    var isAutoStar = IsAutoDetectedStar(item, starInfo.Id);
                                    <button type="button" class="btn btn-primary star-pill @(isAutoStar ? "auto-detected" : "")" @onclick="() => AddStarFilter(starInfo.Name)">
                                        @if (isAutoStar) { <i class="icon-sparkles"></i> }
                                        <i class="icon-user"></i> @starInfo.Name
                                    </button>
                                }
                            </div>
                        }
                        <div class="tag-container">
                            @if (item.Tags != null)
                            {
                                @foreach (var tagInfo in item.Tags)
                                {
                                    var isAutoTag = IsAutoDetectedTag(item, tagInfo.Id);
                                    <button type="button" class="btn btn-primary tag-pill @(isAutoTag ? "auto-detected" : "")" @onclick="() => AddTagFilter(tagInfo.Name)">
                                        @tagInfo.Name
                                    </button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <Pager CurrentPage="CurrentPage" TotalPages="TotalPages" PageSize="PageSize"
               IsFirstPage="IsFirstPage" IsLastPage="IsLastPage"
               OnPageChanged="GoToPage" OnPageSizeChanged="PageSizeChanged" />
    </div>
</div>

