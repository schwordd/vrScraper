                    }
                    @if (item.Stars != null && item.Stars.Any())
                    {
                        <div class="star-container">
                            @foreach (var starInfo in item.Stars)
                            {
                                var isAutoStar = IsAutoDetectedStar(item, starInfo.Id);
                                <button type="button" class="btn btn-primary star-pill @(isAutoStar ? "auto-detected" : "")" @onclick="() => AddStarFilter(starInfo.Name)">
                                    @if (isAutoStar) { <i class="icon-sparkles"></i> }
                                    <i class="icon-user"></i> @starInfo.Name
                                </button>
                            }
                        </div>
                    }
                    <div class="tag-container">
                        @if (item.Tags != null)
                        {
                            @foreach (var tagInfo in item.Tags)
                            {
                                var isAutoTag = IsAutoDetectedTag(item, tagInfo.Id);
                                <button type="button" class="btn btn-primary tag-pill @(isAutoTag ? "auto-detected" : "")" @onclick="() => AddTagFilter(tagInfo.Name)">
                                    @tagInfo.Name
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Video-Player-Komponente hinzufügen -->
<VideoPlayer @ref="VideoPlayerComponent" OnClose="HandlePlayerClosed" />

@code {

    private bool _isLoading = true;

    private int _minDurationMinutes = 0;
    private int _maxDurationMinutes = 120;
    private const int DurationSliderMax = 120;

    public int MinDurationMinutes { get => _minDurationMinutes; set { _minDurationMinutes = value; CurrentPage = 1; _cachedRandomItems = null; SyncUrlState(); } }
    public int MaxDurationMinutes { get => _maxDurationMinutes; set { _maxDurationMinutes = value; CurrentPage = 1; _cachedRandomItems = null; SyncUrlState(); } }

    public List<string> _selectedTags = new List<string>();
    public IEnumerable<string> SelectedTagValues
    {
        get
        {
            return this._selectedTags;
        }
        set
        {
            this._selectedTags = value.ToList();
            OnTagsChanged(this._selectedTags);
        }
    }

    public List<string> _selectedActresses = new List<string>();
    public IEnumerable<string> SelectedActressesValues
    {
        get
        {
            return this._selectedActresses;
        }
        set
        {
            this._selectedActresses = value.ToList();
            OnActressesChanged(this._selectedActresses);
        }
    }

    public int TotalItems { get { return this.FilteredItems.Count; } }

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 30;

    private List<DbVideoItem> _videoItems = new();
    private List<string> _globalBlackList = new();

    private List<DbVideoItem> VideoItems => _videoItems;
    private string _currentSortOption = "latest";

    private string _searchQuery = "";
    public string SearchQuery
    {
        get => _searchQuery;
        set
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    private bool _showOnlyLiked;
    private bool _showOnlyUnwatched;
    private bool _showOnlyWithErrors;
    private bool _showOnlyWatchlist;
    private Random rng = new Random();
    private List<DbVideoItem>? _cachedRandomItems = null;
    private string? _lastRandomSeed = null;

    public bool ShowOnlyLiked
    {
        get => _showOnlyLiked;
        set
        {
            if (_showOnlyLiked != value)
            {
                _showOnlyLiked = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    public bool ShowOnlyUnwatched
    {
        get => _showOnlyUnwatched;
        set
        {
            if (_showOnlyUnwatched != value)
            {
                _showOnlyUnwatched = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    public bool ShowOnlyWithErrors
    {
        get => _showOnlyWithErrors;
        set
        {
            if (_showOnlyWithErrors != value)
            {
                _showOnlyWithErrors = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    public string CurrentSortOption
    {
        get => _currentSortOption;
        set
        {
            if (_currentSortOption != value)
            {
                _currentSortOption = value;
                CurrentPage = 1; // Reset page on sort change
                
                // Clear random cache when switching away from random
                if (value != "random")
                {
                    _cachedRandomItems = null;
                    _lastRandomSeed = null;
                }
                // Generate new random seed when switching to random
                else if (value == "random")
                {
                    _lastRandomSeed = Guid.NewGuid().ToString();
                    _cachedRandomItems = null;
                }
                SyncUrlState();
            }
        }
    }

    private List<DbVideoItem> FilteredItems
    {
        get
        {
            // Use cached random items if in random mode and cache exists
            if (_currentSortOption == "random" && _cachedRandomItems != null)
            {
                return _cachedRandomItems;
            }
            
            var items = VideoItems;

            // Apply global tag blacklist
            items = items.Where(item => !item.Tags.Exists(a => _globalBlackList.Any(b => b == a.Name))).ToList();

            // Apply site filter
            if (_selectedSites.Any())
            {
                items = items.Where(v => _selectedSites.Contains(v.Site)).ToList();
            }

            // Apply filters
            var filteredItems = items
                .Where(v => (!_showOnlyLiked || v.Liked) &&
                        (!_showOnlyUnwatched || v.PlayCount == 0) &&
                        (!_showOnlyWithErrors || (v.ErrorCount ?? 0) > 0) &&
                        (!_showOnlyWatchlist || _selectedWatchlistVideoIds.Contains(v.Id)) &&
                        (string.IsNullOrEmpty(_searchQuery) || v.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || (v.NormalizedTitle != null && v.NormalizedTitle.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))) &&
                        (SelectedTags.Count == 0 || SelectedTags.All(t => v.Tags.Any(a => a.Name == t))) &&
                        (SelectedActresses.Count == 0 || SelectedActresses.All(t => v.Stars.Any(a => a.Name == t))) &&
                        (_minDurationMinutes <= 0 || v.Duration.TotalMinutes >= _minDurationMinutes) &&
                        (_maxDurationMinutes >= DurationSliderMax || v.Duration.TotalMinutes <= _maxDurationMinutes));

            // Apply sorting
            List<DbVideoItem> sortedItems;
            if (_currentSortOption == "random")
            {
                // Create stable random order using seed
                var seed = _lastRandomSeed?.GetHashCode() ?? 0;
                var seededRng = new Random(seed);
                sortedItems = filteredItems
                    .Select(v => new { Item = v, Order = seededRng.Next() })
                    .OrderByDescending(x => x.Order)
                    .Select(x => x.Item)
                    .ToList();

                // Cache the random order
                _cachedRandomItems = sortedItems;
            }
            else if (_currentSortOption == "bestunwatched")
            {
                // Best unwatched: filter unwatched and sort by Bayesian Average
                var allUnwatched = filteredItems.Where(v => v.PlayCount == 0).ToList();
                var k = 16000; // Tuning-Parameter
                var averageRating = items.Where(a => a.SiteRating.HasValue).Average(a => a.SiteRating);

                sortedItems = allUnwatched
                    .Where(a => a.Views.HasValue && a.SiteRating.HasValue)
                    .OrderByDescending(a =>
                        ((a.Views!.Value / (double)(a.Views.Value + k)) * a.SiteRating!.Value) +
                        ((k / (double)(a.Views.Value + k)) * averageRating)
                    )
                    .ToList();
            }
            else if (_currentSortOption == "recommended")
            {
                // Always compute recommendations from full video list, then intersect with filters
                var recommended = RecommendationService.GetRecommendedVideos(VideoItems);
                var filteredIds = filteredItems.Select(v => v.Id).ToHashSet();
                sortedItems = recommended.Where(v => filteredIds.Contains(v.Id)).ToList();
            }
            else if (_currentSortOption == "recentlywatched")
            {
                sortedItems = filteredItems
                    .Where(v => v.LastPlayedUtc.HasValue)
                    .OrderByDescending(v => v.LastPlayedUtc!.Value)
                    .ToList();
            }
            else
            {
                sortedItems = filteredItems
                    .OrderByDescending(v => _currentSortOption switch
                    {
                        "latest" => (double)v.Id,
                        "rating" => v.SiteRating ?? 0,
                        "playtime" => v.PlayDurationEst.TotalSeconds,
                        "playcount" => v.PlayCount,
                        _ => (double)v.Id
                    })
                    .ToList();
            }
            
            return sortedItems;
        }
    }

    private List<DbTag> AllTags { get { return this.AvailableTags.Select(x => x.Tag).ToList(); } }
    private List<DbStar> AllStars { get { return this.AvailableActresses.Select(x => x.Star).ToList(); } }

    private List<(DbTag Tag, long Count)> AvailableTags { get; set; } = new();
    private List<(DbStar Star, long Count)> AvailableActresses { get; set; } = new();

    private HashSet<string> SelectedTags { get; set; } = new();
    private HashSet<string> SelectedActresses { get; set; } = new();

    private List<DbVideoItem> PagedItems => FilteredItems.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredItems.Count / (double)PageSize);

    private bool IsFirstPage => CurrentPage == 1;
    private bool IsLastPage => CurrentPage == TotalPages;

    private List<DbVideoItem> BaseFilteredItems
    {
        get
        {
            var items = VideoItems;
            items = items.Where(item => !item.Tags.Exists(a => _globalBlackList.Any(b => b == a.Name))).ToList();
            if (_selectedSites.Any())
                items = items.Where(v => _selectedSites.Contains(v.Site)).ToList();
            return items
                .Where(v => (!_showOnlyLiked || v.Liked) &&
                        (!_showOnlyUnwatched || v.PlayCount == 0) &&
                        (!_showOnlyWithErrors || (v.ErrorCount ?? 0) > 0) &&
                        (!_showOnlyWatchlist || _selectedWatchlistVideoIds.Contains(v.Id)) &&
                        (string.IsNullOrEmpty(_searchQuery) || v.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || (v.NormalizedTitle != null && v.NormalizedTitle.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))) &&
                        (_minDurationMinutes <= 0 || v.Duration.TotalMinutes >= _minDurationMinutes) &&
                        (_maxDurationMinutes >= DurationSliderMax || v.Duration.TotalMinutes <= _maxDurationMinutes))
                .ToList();
        }
    }

    private List<(DbTag Tag, long Count)> SortedTags
    {
        get
        {
            var baseItems = BaseFilteredItems;
            if (SelectedActresses.Count > 0)
                baseItems = baseItems.Where(v => SelectedActresses.All(a => v.Stars.Any(s => s.Name == a))).ToList();
            var tagCounts = baseItems
                .SelectMany(v => v.Tags)
                .GroupBy(t => t.Name)
                .ToDictionary(g => g.Key, g => (long)g.Count());
            return AvailableTags
                .Select(t => (t.Tag, Count: tagCounts.GetValueOrDefault(t.Tag.Name, 0)))
                .Where(t => t.Count > 0 || SelectedTags.Contains(t.Tag.Name))
                .OrderByDescending(t => SelectedTags.Contains(t.Tag.Name))
                .ThenByDescending(t => t.Count)
                .ToList();
        }
    }

    private List<(DbStar Star, long Count)> SortedActresses
    {
        get
        {
            var baseItems = BaseFilteredItems;
            if (SelectedTags.Count > 0)
                baseItems = baseItems.Where(v => SelectedTags.All(t => v.Tags.Any(a => a.Name == t))).ToList();
            var starCounts = baseItems
                .SelectMany(v => v.Stars)
                .GroupBy(s => s.Name)
                .ToDictionary(g => g.Key, g => (long)g.Count());
            return AvailableActresses
                .Select(a => (a.Star, Count: starCounts.GetValueOrDefault(a.Star.Name, 0)))
                .Where(a => a.Count > 0 || SelectedActresses.Contains(a.Star.Name))
                .OrderByDescending(a => SelectedActresses.Contains(a.Star.Name))
                .ThenByDescending(a => a.Count)
                .ToList();
        }
    }

    private List<DbVrTab> WatchlistTabs { get; set; } = new();
    private long _selectedWatchlistId;
    private HashSet<long> _selectedWatchlistVideoIds = new();

    private List<string> AvailableSites { get; set; } = new();
    private List<string> _selectedSites = new();
    public IEnumerable<string> SelectedSitesValues
    {
