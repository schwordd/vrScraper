@page "/videos"

@using Newtonsoft.Json
@using vrScraper.DB.Models
@using vrScraper.Services
@using vrScraper.Components

@inject IVideoService VideoService
@inject ISettingService SettingService
@inject ITabService TabService
@inject IJSRuntime JSRuntime
@inject IServiceProvider serviceProvider
@inject IRecommendationService RecommendationService
@inject IScraperRegistry ScraperRegistry
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<div class="main-container">

    <div class="filters vr-panel">
        <div class="filter-row">
            <span class="filter-item">
                <div class="search-wrapper">
                    <i class="icon-search search-icon"></i>
                    <input type="text" class="form-control filter-search" id="search"
                           placeholder="Search title..."
                           @bind="SearchQuery"
                           @bind:event="oninput" />
                </div>
            </span>

            <span class="filter-item">
                <label>Sort:</label>
                <select class="form-select filter-select" @bind="CurrentSortOption" title="Choose how videos are ordered">
                    <option value="latest">Latest</option>
                    <option value="recommended">Recommended</option>
                    <option value="bestunwatched">Best unwatched</option>
                    <option value="rating">Rating</option>
                    <option value="random">Random</option>
                    <option value="playtime">Most played time</option>
                    <option value="playcount">Most played count</option>
                    <option value="recentlywatched">Recently watched</option>
                </select>
            </span>

            <span class="filter-separator"></span>

            <span class="filter-item" title="Show only videos you have liked">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="ShowOnlyLiked" id="showLikedCheck">
                    <label class="form-check-label" for="showLikedCheck">Liked</label>
                </div>
            </span>

            <span class="filter-item" title="Show only videos you haven't watched yet">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="ShowOnlyUnwatched" id="showUnwatchedCheck">
                    <label class="form-check-label" for="showUnwatchedCheck">Unwatched</label>
                </div>
            </span>

            <span class="filter-item" title="Show only videos with playback errors (e.g. broken streams or missing files)">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="ShowOnlyWithErrors" id="showErrorsCheck">
                    <label class="form-check-label" for="showErrorsCheck">Errors</label>
                </div>
            </span>

            <span class="filter-item-count">@TotalItems videos</span>
        </div>

        <div class="filter-row">
            <span class="filter-item">
                <label>Tags:</label>
                <div class="d-flex align-items-center gap-2">
                    <MultiSelect IsMultiple="true"
                                    TItem="(DbTag Tag, long Count)"
                                    Data="@SortedTags"
                                    TextField="@((item) => $"{item.Tag.Name} ({item.Count})")"
                                    ValueField="@((item) => item.Tag.Name)"
                                    ShowSearch="true"
                                    @bind-SelectedValues="@SelectedTagValues" />
                    <button class="btn btn-sm btn-clear" @onclick="ClearTags" disabled="@(SelectedTags.Count == 0)" title="Remove all selected tag filters">
                        <i class="icon-x"></i>
                    </button>
                </div>
            </span>

            <span class="filter-item">
                <label>Actresses:</label>
                <div class="d-flex align-items-center gap-2">
                    <MultiSelect IsMultiple="true"
                                    TItem="(DbStar Star, long Count)"
                                    Data="@SortedActresses"
                                    TextField="@((item) => $"{item.Star.Name} ({item.Count})")"
                                    ValueField="@((item) => item.Star.Name)"
                                    ShowSearch="true"
                                    @bind-SelectedValues="@SelectedActressesValues" />
                    <button class="btn btn-sm btn-clear" @onclick="ClearActresses" disabled="@(SelectedActresses.Count == 0)" title="Remove all selected actress filters">
                        <i class="icon-x"></i>
                    </button>
                </div>
            </span>

            @if (AvailableSites.Count > 1)
            {
                <span class="filter-item">
                    <label>Site:</label>
                    <div class="d-flex align-items-center gap-2">
                        <MultiSelect IsMultiple="true" TItem="string" Data="@AvailableSites"
                                        TextField="@((item) => item)" ValueField="@((item) => item)"
                                        @bind-SelectedValues="@SelectedSitesValues" />
                        <button class="btn btn-sm btn-clear" @onclick="ClearSites" disabled="@(_selectedSites.Count == 0)" title="Remove all selected site filters">
                            <i class="icon-x"></i>
                        </button>
                    </div>
                </span>
            }

            <span class="filter-item">
                <label>Duration:</label>
                <DualRangeSlider Min="0" Max="120" Step="5"
                                 @bind-MinValue="MinDurationMinutes"
                                 @bind-MaxValue="MaxDurationMinutes" />
            </span>

            <span class="filter-separator"></span>

            <span class="filter-item watchlist-filter">
                <label><i class="icon-bookmark"></i> Watchlist:</label>
                @if (_isCreatingWatchlist)
                {
                    <div class="watchlist-create-inline">
                        <input type="text" class="form-control form-control-sm" placeholder="Name..."
                               @bind="_newWatchlistName" @bind:event="oninput"
                               @onkeydown="OnNewWatchlistKeyDown" />
                        <button class="btn btn-sm btn-success" @onclick="CreateWatchlistConfirm"
                                disabled="@string.IsNullOrWhiteSpace(_newWatchlistName)" title="Create">
                            <i class="icon-check"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _isCreatingWatchlist = false" title="Cancel">
                            <i class="icon-x"></i>
                        </button>
                    </div>
                }
                else
                {
                    <MultiSelect TItem="DbVrTab"
                                    Data="@WatchlistTabs"
                                    TextField="@((item) => item.Name)"
                                    ValueField="@((item) => item.Id.ToString())"
                                    Placeholder="Select..."
                                    @bind-Value="@SelectedWatchlistValue" />
                    @if (_selectedWatchlistId > 0)
                    {
                        <button class="btn btn-sm @(_showOnlyWatchlist ? "btn-success watchlist-filter-active" : "btn-outline-success")"
                                @onclick="() => ToggleShowOnlyWatchlist()"
                                title="@(_showOnlyWatchlist ? "Showing only watchlist videos — click to show all" : "Show only videos in this watchlist")">
                            <i class="icon-filter"></i>
                        </button>
                    }
                    <button class="btn btn-sm btn-outline-primary" @onclick="StartCreateWatchlist" title="Create a new watchlist">
                        <i class="icon-plus"></i>
                    </button>
                }
            </span>
        </div>
    </div>

    <div class="content-wrapper">
        <Pager CurrentPage="CurrentPage" TotalPages="TotalPages" PageSize="PageSize"
               IsFirstPage="IsFirstPage" IsLastPage="IsLastPage"
               OnPageChanged="GoToPage" OnPageSizeChanged="PageSizeChanged" />

        @if (_isLoading)
        {
            <div class="video-gallery">
                <SkeletonCard Count="@PageSize" />
            </div>
        }
        else if (!PagedItems.Any())
        {
            <div class="empty-state">
                @if (_showOnlyWatchlist && _selectedWatchlistId > 0 && !_selectedWatchlistVideoIds.Any())
                {
                    <i class="icon-bookmark"></i>
                    <p>This watchlist is empty.</p>
                    <span>Add videos by selecting a watchlist and clicking the bookmark icon on any video.</span>
                }
                else if (_showOnlyLiked && FilteredItems.Count == 0)
                {
                    <i class="icon-heart"></i>
                    <p>No liked videos yet.</p>
                    <span>Click the heart icon on videos you enjoy to find them here later.</span>
                }
                else if (_showOnlyUnwatched && FilteredItems.Count == 0)
                {
                    <i class="icon-play-circle"></i>
                    <p>All videos have been watched.</p>
                    <span>Scrape new content to discover fresh videos.</span>
                }
                else if (_showOnlyWithErrors && FilteredItems.Count == 0)
                {
                    <i class="icon-check-circle"></i>
                    <p>No videos with errors.</p>
                    <span>All videos are working fine.</span>
                }
                else
                {
                    <i class="icon-search"></i>
                    <p>No videos match your filters.</p>
                    <span>Try adjusting your search, tags, actresses, or other filter settings.</span>
                }
            </div>
        }
        else
        {
            <div class="video-gallery">
                @foreach (var item in PagedItems)
                {
                    <VideoCard Item="item"
                               SelectedWatchlistId="_selectedWatchlistId"
                               IsInWatchlist="IsInSelectedWatchlist(item.Id)"
                               OnPlay="PlayVideo"
                               OnDelete="DeleteVideo"
                               OnShowSimilar="ShowSimilar"
                               OnDownload="DownloadVideo"
                               OnToggleLike="ToggleLike"
                               OnToggleWatchlist="ToggleWatchlist"
                               OnAddStarFilter="AddStarFilter"
                               OnAddTagFilter="AddTagFilter"
                               OnImageError="HandleImageErrorFromCard" />
                }
            </div>
        }

        <Pager CurrentPage="CurrentPage" TotalPages="TotalPages" PageSize="PageSize"
               IsFirstPage="IsFirstPage" IsLastPage="IsLastPage"
               OnPageChanged="GoToPage" OnPageSizeChanged="PageSizeChanged" />
    </div>
</div>

@if (_similarVideos != null && _similarVideos.Any())
{
    <div class="similar-panel">
        <div class="similar-header">
            <h5><i class="icon-sparkles"></i> Similar to: @_similarToTitle</h5>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CloseSimilar">
                <i class="icon-x"></i>
            </button>
        </div>
        <div class="video-gallery">
            @foreach (var scored in _similarVideos)
            {
                <VideoCard Item="scored.Video"
                           SelectedWatchlistId="_selectedWatchlistId"
                           IsInWatchlist="IsInSelectedWatchlist(scored.Video.Id)"
                           OnPlay="PlayVideo"
                           OnDelete="DeleteVideo"
                           OnShowSimilar="ShowSimilar"
                           OnDownload="DownloadVideo"
                           OnToggleLike="ToggleLike"
                           OnToggleWatchlist="ToggleWatchlist"
                           OnAddStarFilter="AddStarFilter"
                           OnAddTagFilter="AddTagFilter"
                           OnImageError="HandleImageErrorFromCard"
                           SimilarityScore="@scored.Score" />
            }
        </div>
    </div>
}

<!-- Video-Player-Komponente hinzufügen -->
<VideoPlayer @ref="VideoPlayerComponent"
             OnClose="HandlePlayerClosed"
             HasNext="_playerHasNext"
             HasPrevious="_playerHasPrevious"
             VideoIndex="_currentPlayerIndex"
             VideoListCount="_playerListCount"
             SelectedWatchlistId="_selectedWatchlistId"
             IsInWatchlist="_playerVideoInWatchlist"
             OnNavigateNext="NavigatePlayerNext"
             OnNavigatePrevious="NavigatePlayerPrevious"
             OnToggleLike="ToggleLike"
             OnToggleWatchlist="ToggleWatchlist" />

@code {

    private bool _isLoading = true;

    private int _minDurationMinutes = 0;
    private int _maxDurationMinutes = 120;
    private const int DurationSliderMax = 120;

    public int MinDurationMinutes { get => _minDurationMinutes; set { _minDurationMinutes = value; CurrentPage = 1; _cachedRandomItems = null; SyncUrlState(); } }
    public int MaxDurationMinutes { get => _maxDurationMinutes; set { _maxDurationMinutes = value; CurrentPage = 1; _cachedRandomItems = null; SyncUrlState(); } }

    public List<string> _selectedTags = new List<string>();
    public IEnumerable<string> SelectedTagValues
    {
        get
        {
            return this._selectedTags;
        }
        set
        {
            this._selectedTags = value.ToList();
            OnTagsChanged(this._selectedTags);
        }
    }

    public List<string> _selectedActresses = new List<string>();
    public IEnumerable<string> SelectedActressesValues
    {
        get
        {
            return this._selectedActresses;
        }
        set
        {
            this._selectedActresses = value.ToList();
            OnActressesChanged(this._selectedActresses);
        }
    }

    public int TotalItems { get { return this.FilteredItems.Count; } }

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 30;

    private List<DbVideoItem> _videoItems = new();
    private List<string> _globalBlackList = new();

    private List<DbVideoItem> VideoItems => _videoItems;
    private string _currentSortOption = "latest";

    private string _searchQuery = "";
    public string SearchQuery
    {
        get => _searchQuery;
        set
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    private bool _showOnlyLiked;
    private bool _showOnlyUnwatched;
    private bool _showOnlyWithErrors;
    private bool _showOnlyWatchlist;
    private Random rng = new Random();
    private List<DbVideoItem>? _cachedRandomItems = null;
    private string? _lastRandomSeed = null;

    public bool ShowOnlyLiked
    {
        get => _showOnlyLiked;
        set
        {
            if (_showOnlyLiked != value)
            {
                _showOnlyLiked = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    public bool ShowOnlyUnwatched
    {
        get => _showOnlyUnwatched;
        set
        {
            if (_showOnlyUnwatched != value)
            {
                _showOnlyUnwatched = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    public bool ShowOnlyWithErrors
    {
        get => _showOnlyWithErrors;
        set
        {
            if (_showOnlyWithErrors != value)
            {
                _showOnlyWithErrors = value;
                CurrentPage = 1;
                _cachedRandomItems = null;
                SyncUrlState();
            }
        }
    }

    public string CurrentSortOption
    {
        get => _currentSortOption;
        set
        {
            if (_currentSortOption != value)
            {
                _currentSortOption = value;
                CurrentPage = 1; // Reset page on sort change
                
                // Clear random cache when switching away from random
                if (value != "random")
                {
                    _cachedRandomItems = null;
                    _lastRandomSeed = null;
                }
                // Generate new random seed when switching to random
                else if (value == "random")
                {
                    _lastRandomSeed = Guid.NewGuid().ToString();
                    _cachedRandomItems = null;
                }
                SyncUrlState();
            }
        }
    }

    private List<DbVideoItem> FilteredItems
    {
        get
        {
            // Use cached random items if in random mode and cache exists
            if (_currentSortOption == "random" && _cachedRandomItems != null)
            {
                return _cachedRandomItems;
            }
            
            var items = VideoItems;

            // Apply global tag blacklist
            items = items.Where(item => !item.Tags.Exists(a => _globalBlackList.Any(b => b == a.Name))).ToList();

            // Apply site filter
            if (_selectedSites.Any())
            {
                items = items.Where(v => _selectedSites.Contains(v.Site)).ToList();
            }

            // Apply filters
            var filteredItems = items
                .Where(v => (!_showOnlyLiked || v.Liked) &&
                        (!_showOnlyUnwatched || v.PlayCount == 0) &&
                        (!_showOnlyWithErrors || (v.ErrorCount ?? 0) > 0) &&
                        (!_showOnlyWatchlist || _selectedWatchlistVideoIds.Contains(v.Id)) &&
                        (string.IsNullOrEmpty(_searchQuery) || v.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || (v.NormalizedTitle != null && v.NormalizedTitle.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))) &&
                        (SelectedTags.Count == 0 || SelectedTags.All(t => v.Tags.Any(a => a.Name == t))) &&
                        (SelectedActresses.Count == 0 || SelectedActresses.All(t => v.Stars.Any(a => a.Name == t))) &&
                        (_minDurationMinutes <= 0 || v.Duration.TotalMinutes >= _minDurationMinutes) &&
                        (_maxDurationMinutes >= DurationSliderMax || v.Duration.TotalMinutes <= _maxDurationMinutes));

            // Apply sorting
            List<DbVideoItem> sortedItems;
            if (_currentSortOption == "random")
            {
                // Create stable random order using seed
                var seed = _lastRandomSeed?.GetHashCode() ?? 0;
                var seededRng = new Random(seed);
                sortedItems = filteredItems
                    .Select(v => new { Item = v, Order = seededRng.Next() })
                    .OrderByDescending(x => x.Order)
                    .Select(x => x.Item)
                    .ToList();

                // Cache the random order
                _cachedRandomItems = sortedItems;
            }
            else if (_currentSortOption == "bestunwatched")
            {
                // Best unwatched: filter unwatched and sort by Bayesian Average
                var allUnwatched = filteredItems.Where(v => v.PlayCount == 0).ToList();
                var k = 16000; // Tuning-Parameter
                var averageRating = items.Where(a => a.SiteRating.HasValue).Average(a => a.SiteRating);

                sortedItems = allUnwatched
                    .Where(a => a.Views.HasValue && a.SiteRating.HasValue)
                    .OrderByDescending(a =>
                        ((a.Views!.Value / (double)(a.Views.Value + k)) * a.SiteRating!.Value) +
                        ((k / (double)(a.Views.Value + k)) * averageRating)
                    )
                    .ToList();
            }
            else if (_currentSortOption == "recommended")
            {
                // Always compute recommendations from full video list, then intersect with filters
                var recommended = RecommendationService.GetRecommendedVideos(VideoItems);
                var filteredIds = filteredItems.Select(v => v.Id).ToHashSet();
                sortedItems = recommended.Where(s => filteredIds.Contains(s.Video.Id)).Select(s => s.Video).ToList();
            }
            else if (_currentSortOption == "recentlywatched")
            {
                sortedItems = filteredItems
                    .Where(v => v.LastPlayedUtc.HasValue)
                    .OrderByDescending(v => v.LastPlayedUtc!.Value)
                    .ToList();
            }
            else
            {
                sortedItems = filteredItems
                    .OrderByDescending(v => _currentSortOption switch
                    {
                        "latest" => (double)v.Id,
                        "rating" => v.SiteRating ?? 0,
                        "playtime" => v.PlayDurationEst.TotalSeconds,
                        "playcount" => v.PlayCount,
                        _ => (double)v.Id
                    })
                    .ToList();
            }
            
            return sortedItems;
        }
    }

    private List<DbTag> AllTags { get { return this.AvailableTags.Select(x => x.Tag).ToList(); } }
    private List<DbStar> AllStars { get { return this.AvailableActresses.Select(x => x.Star).ToList(); } }

    private List<(DbTag Tag, long Count)> AvailableTags { get; set; } = new();
    private List<(DbStar Star, long Count)> AvailableActresses { get; set; } = new();

    private HashSet<string> SelectedTags { get; set; } = new();
    private HashSet<string> SelectedActresses { get; set; } = new();

    private List<DbVideoItem> PagedItems => FilteredItems.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredItems.Count / (double)PageSize);

    private bool IsFirstPage => CurrentPage == 1;
    private bool IsLastPage => CurrentPage == TotalPages;

    private List<DbVideoItem> BaseFilteredItems
    {
        get
        {
            var items = VideoItems;
            items = items.Where(item => !item.Tags.Exists(a => _globalBlackList.Any(b => b == a.Name))).ToList();
            if (_selectedSites.Any())
                items = items.Where(v => _selectedSites.Contains(v.Site)).ToList();
            return items
                .Where(v => (!_showOnlyLiked || v.Liked) &&
                        (!_showOnlyUnwatched || v.PlayCount == 0) &&
                        (!_showOnlyWithErrors || (v.ErrorCount ?? 0) > 0) &&
                        (!_showOnlyWatchlist || _selectedWatchlistVideoIds.Contains(v.Id)) &&
                        (string.IsNullOrEmpty(_searchQuery) || v.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || (v.NormalizedTitle != null && v.NormalizedTitle.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))) &&
                        (_minDurationMinutes <= 0 || v.Duration.TotalMinutes >= _minDurationMinutes) &&
                        (_maxDurationMinutes >= DurationSliderMax || v.Duration.TotalMinutes <= _maxDurationMinutes))
                .ToList();
        }
    }

    private List<(DbTag Tag, long Count)> SortedTags
    {
        get
        {
            var baseItems = BaseFilteredItems;
            if (SelectedActresses.Count > 0)
                baseItems = baseItems.Where(v => SelectedActresses.All(a => v.Stars.Any(s => s.Name == a))).ToList();
            var tagCounts = baseItems
                .SelectMany(v => v.Tags)
                .GroupBy(t => t.Name)
                .ToDictionary(g => g.Key, g => (long)g.Count());
            return AvailableTags
                .Select(t => (t.Tag, Count: tagCounts.GetValueOrDefault(t.Tag.Name, 0)))
                .Where(t => t.Count > 0 || SelectedTags.Contains(t.Tag.Name))
                .OrderByDescending(t => SelectedTags.Contains(t.Tag.Name))
                .ThenByDescending(t => t.Count)
                .ToList();
        }
    }

    private List<(DbStar Star, long Count)> SortedActresses
    {
        get
        {
            var baseItems = BaseFilteredItems;
            if (SelectedTags.Count > 0)
                baseItems = baseItems.Where(v => SelectedTags.All(t => v.Tags.Any(a => a.Name == t))).ToList();
            var starCounts = baseItems
                .SelectMany(v => v.Stars)
                .GroupBy(s => s.Name)
                .ToDictionary(g => g.Key, g => (long)g.Count());
            return AvailableActresses
                .Select(a => (a.Star, Count: starCounts.GetValueOrDefault(a.Star.Name, 0)))
                .Where(a => a.Count > 0 || SelectedActresses.Contains(a.Star.Name))
                .OrderByDescending(a => SelectedActresses.Contains(a.Star.Name))
                .ThenByDescending(a => a.Count)
                .ToList();
        }
    }

    private List<DbVrTab> WatchlistTabs { get; set; } = new();
    private long _selectedWatchlistId;
    private HashSet<long> _selectedWatchlistVideoIds = new();

    private List<string> AvailableSites { get; set; } = new();
    private List<string> _selectedSites = new();
    public IEnumerable<string> SelectedSitesValues
    {
        get => _selectedSites;
        set { _selectedSites = value.ToList(); CurrentPage = 1; _cachedRandomItems = null; SyncUrlState(); }
    }
    private void ClearSites() { SelectedSitesValues = new List<string>(); }

    public string SelectedWatchlistValue
    {
        get => _selectedWatchlistId == 0 ? "" : _selectedWatchlistId.ToString();
        set
        {
            SelectedWatchlistId = long.TryParse(value, out var id) ? id : 0;
        }
    }

    public long SelectedWatchlistId
    {
        get => _selectedWatchlistId;
        set
        {
            _selectedWatchlistId = value;
            UpdateWatchlistVideoIds();
        }
    }

    private void ToggleShowOnlyWatchlist()
    {
        _showOnlyWatchlist = !_showOnlyWatchlist;
        CurrentPage = 1;
        _cachedRandomItems = null;
    }

    private void UpdateWatchlistVideoIds()
    {
        if (_selectedWatchlistId == 0)
        {
            _selectedWatchlistVideoIds.Clear();
            return;
        }
        var wl = WatchlistTabs.FirstOrDefault(t => t.Id == _selectedWatchlistId);
        if (wl != null)
        {
            _selectedWatchlistVideoIds = wl.VideoWhitelistList
                .Select(v => Convert.ToInt64(v))
                .ToHashSet();
        }
        else
        {
            _selectedWatchlistVideoIds.Clear();
        }
    }

    private bool _isCreatingWatchlist;
    private string _newWatchlistName = "";

    private void StartCreateWatchlist()
    {
        _newWatchlistName = "";
        _isCreatingWatchlist = true;
    }

    private async Task CreateWatchlistConfirm()
    {
        if (string.IsNullOrWhiteSpace(_newWatchlistName)) return;

        var newTab = new DbVrTab
        {
            Name = _newWatchlistName.Trim(),
            Type = "WATCHLIST",
            Active = true,
            Order = WatchlistTabs.Count + 1,
            TagWhitelist = "[]",
            ActressWhitelist = "[]",
            TagBlacklist = "[]",
            ActressBlacklist = "[]",
            VideoWhitelist = "[]",
            VideoBlacklist = "[]",
            SiteFilter = "[]"
        };

        await TabService.AddTab(newTab);
        WatchlistTabs = TabService.GetWatchlistTabs();
        SelectedWatchlistId = newTab.Id;
        _isCreatingWatchlist = false;
        _newWatchlistName = "";
    }

    private async Task OnNewWatchlistKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateWatchlistConfirm();
        else if (e.Key == "Escape") _isCreatingWatchlist = false;
    }

    private bool IsInSelectedWatchlist(long videoId)
    {
        return _selectedWatchlistVideoIds.Contains(videoId);
    }

    private async Task ToggleWatchlist(long videoId)
    {
        if (_selectedWatchlistId == 0) return;

        if (IsInSelectedWatchlist(videoId))
        {
            await TabService.RemoveVideoFromWatchlist(_selectedWatchlistId, videoId);
            _selectedWatchlistVideoIds.Remove(videoId);
        }
        else
        {
            await TabService.AddVideoToWatchlist(_selectedWatchlistId, videoId);
            _selectedWatchlistVideoIds.Add(videoId);
        }

        WatchlistTabs = TabService.GetWatchlistTabs();
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        _videoItems = await VideoService.GetVideoItems();
        var setting = await SettingService.GetSetting("TagBlacklist");
        if (setting != null)
            _globalBlackList = JsonConvert.DeserializeObject<List<string>>(setting.Value) ?? new List<string>();

        await LoadVideos();
        await LoadTags();
        await LoadActresses();
        WatchlistTabs = TabService.GetWatchlistTabs();
        AvailableSites = ScraperRegistry.GetEnabledSiteNames().ToList();
        RestoreFiltersFromUrl();
        _isLoading = false;
    }

    private async Task LoadVideos()
    {
        // Nur noch für das initiale Laden der Seite benötigt
        CurrentPage = 1;
        StateHasChanged();
    }

    private async Task LoadTags()
    {
        AvailableTags = await this.VideoService.GetTagInfos();
    }

    private async Task LoadActresses()
    {
        AvailableActresses = await this.VideoService.GetActorInfos();
    }

    private void OnTagsChanged(IEnumerable<string> e)
    {
        SelectedTags = e.ToHashSet();
        CurrentPage = 1;
        _cachedRandomItems = null;
        SyncUrlState();
    }

    private void OnActressesChanged(IEnumerable<string> e)
    {
        SelectedActresses = e.ToHashSet();
        CurrentPage = 1;
        _cachedRandomItems = null;
        SyncUrlState();
    }

    private void PageSizeChanged(int newSize)
    {
        PageSize = newSize;
        CurrentPage = 1; // Reset page on page size change
    }

    private void AddTagFilter(string tagName)
    {
        var currentTags = _selectedTags.ToList();
        if (!currentTags.Contains(tagName))
        {
            currentTags.Add(tagName);
            SelectedTagValues = currentTags;
        }
    }

    private static bool IsAutoDetectedStar(DbVideoItem video, long starId)
    {
        return video.VideoStars?.Any(vs => vs.StarId == starId && vs.IsAutoDetected) ?? false;
    }

    private static bool IsAutoDetectedTag(DbVideoItem video, long tagId)
    {
        return video.VideoTags?.Any(vt => vt.TagId == tagId && vt.IsAutoDetected) ?? false;
    }

    private void AddStarFilter(string starName)
    {
        var currentStars = _selectedActresses.ToList();
        if (!currentStars.Contains(starName))
        {
            currentStars.Add(starName);
            SelectedActressesValues = currentStars;
        }
    }

    private void ClearTags()
    {
        SelectedTagValues = new List<string>();
    }

    private void ClearActresses()
    {
        SelectedActressesValues = new List<string>();
    }

    private async Task DeleteVideo(long videoId)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this video?");
        if (!confirmed) return;

        await VideoService.DeleteVideo(videoId);

        // Hole das Video für die Tag- und Star-Zähler Aktualisierung
        var videoToRemove = VideoItems.FirstOrDefault(v => v.Id == videoId);
        if (videoToRemove != null)
        {
            _videoItems.Remove(videoToRemove);

            // Aktualisiere die Tag- und Star-Zähler
            foreach (var tag in videoToRemove.Tags)
            {
                var tagInfo = AvailableTags.FirstOrDefault(t => t.Tag.Id == tag.Id);
                if (tagInfo.Count > 0)
                {
                    var index = AvailableTags.IndexOf(tagInfo);
                    AvailableTags[index] = (tagInfo.Tag, tagInfo.Count - 1);
                }
            }

            foreach (var star in videoToRemove.Stars)
            {
                var starInfo = AvailableActresses.FirstOrDefault(s => s.Star.Id == star.Id);
                if (starInfo.Count > 0)
                {
                    var index = AvailableActresses.IndexOf(starInfo);
                    AvailableActresses[index] = (starInfo.Star, starInfo.Count - 1);
                }
            }

            // Wenn die aktuelle Seite leer ist, gehe zur vorherigen Seite
            if (PagedItems.Count == 0 && CurrentPage > 1)
            {
                CurrentPage--;
            }

            // Erzwinge ein UI-Update
            StateHasChanged();
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            CurrentPage = page;
            SyncUrlState();
        }
    }

    private VideoPlayer? VideoPlayerComponent { get; set; }
    private int _currentPlayerIndex = -1;

    private bool _playerHasNext => _currentPlayerIndex >= 0 && _currentPlayerIndex < FilteredItems.Count - 1;
    private bool _playerHasPrevious => _currentPlayerIndex > 0;
    private int _playerListCount => FilteredItems.Count;
    private bool _playerVideoInWatchlist => _currentPlayerIndex >= 0
        && _currentPlayerIndex < FilteredItems.Count
        && IsInSelectedWatchlist(FilteredItems[_currentPlayerIndex].Id);

    private async Task PlayVideo(DbVideoItem item)
    {
        if (VideoPlayerComponent != null)
        {
            _currentPlayerIndex = FilteredItems.IndexOf(item);
            StateHasChanged();
            await VideoPlayerComponent.ShowVideo(item);
        }
    }

    private void HandlePlayerClosed()
    {
        _currentPlayerIndex = -1;
    }

    private async Task NavigatePlayerNext()
    {
        if (!_playerHasNext || VideoPlayerComponent == null) return;
        _currentPlayerIndex++;
        EnsurePageContainsIndex(_currentPlayerIndex);
        StateHasChanged();
        await VideoPlayerComponent.ShowVideo(FilteredItems[_currentPlayerIndex]);
    }

    private async Task NavigatePlayerPrevious()
    {
        if (!_playerHasPrevious || VideoPlayerComponent == null) return;
        _currentPlayerIndex--;
        EnsurePageContainsIndex(_currentPlayerIndex);
        StateHasChanged();
        await VideoPlayerComponent.ShowVideo(FilteredItems[_currentPlayerIndex]);
    }

    private void EnsurePageContainsIndex(int index)
    {
        var targetPage = (index / PageSize) + 1;
        if (targetPage != CurrentPage)
        {
            CurrentPage = targetPage;
            SyncUrlState();
        }
    }

    private async Task ToggleLike(DbVideoItem item)
    {
        item.Liked = !item.Liked;

        // Like-Status in der Datenbank aktualisieren
        await VideoService.UpdateVideoLikeStatus(item.Id, item.Liked);

        StateHasChanged();
    }

    private async Task HandleImageError(Microsoft.AspNetCore.Components.Web.ErrorEventArgs e, DbVideoItem item)
    {
        item.Thumbnail = "/images/thumbnail-not-available.svg";
        item.IsThumbnailNotAvailable = true;

        await VideoService.UpdateVideoErrorCount(item.Id);

        StateHasChanged();
    }

    private async Task HandleImageErrorFromCard((Microsoft.AspNetCore.Components.Web.ErrorEventArgs Error, DbVideoItem Item) args)
    {
        await HandleImageError(args.Error, args.Item);
    }

    private async Task DownloadVideo(DbVideoItem item)
    {
        try
        {
            // Verwende den Backend-Download-Endpoint mit direktem Download
            var downloadUrl = $"/api/VideoProxy/download/{item.Id}";

            // Erstelle einen sicheren Dateinamen
            var safeTitle = System.Text.RegularExpressions.Regex.Replace(item.Title ?? "video", @"[^a-zA-Z0-9_-]", "_");
            var fileName = $"{safeTitle}_{item.SiteVideoId}.mp4";

            // Triggere Download über JavaScript
            await JSRuntime.InvokeVoidAsync("downloadFile", downloadUrl, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error downloading video: {ex.Message}");
        }
    }

    private DotNetObjectReference<Videos>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("addPageKeyListener", _dotNetRef);
            _urlSyncReady = true;
        }
    }

    [JSInvokable]
    public void HandleKeyNavigation(int direction)
    {
        if (direction == -1 && !IsFirstPage)
        {
            GoToPage(CurrentPage - 1);
            StateHasChanged();
        }
        if (direction == 1 && !IsLastPage)
        {
            GoToPage(CurrentPage + 1);
            StateHasChanged();
        }
    }

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalHours >= 1)
            return $"{(int)d.TotalHours}:{d.Minutes:D2}:{d.Seconds:D2}";
        return $"{d.Minutes}:{d.Seconds:D2}";
    }

