    private void ToggleShowOnlyWatchlist()
    {
        _showOnlyWatchlist = !_showOnlyWatchlist;
        CurrentPage = 1;
        _cachedRandomItems = null;
    }

    private void UpdateWatchlistVideoIds()
    {
        if (_selectedWatchlistId == 0)
        {
            _selectedWatchlistVideoIds.Clear();
            return;
        }
        var wl = WatchlistTabs.FirstOrDefault(t => t.Id == _selectedWatchlistId);
        if (wl != null)
        {
            _selectedWatchlistVideoIds = wl.VideoWhitelistList
                .Select(v => Convert.ToInt64(v))
                .ToHashSet();
        }
        else
        {
            _selectedWatchlistVideoIds.Clear();
        }
    }

    private bool IsInSelectedWatchlist(long videoId)
    {
        return _selectedWatchlistVideoIds.Contains(videoId);
    }

    private async Task ToggleWatchlist(long videoId)
    {
        if (_selectedWatchlistId == 0) return;

        if (IsInSelectedWatchlist(videoId))
        {
            await TabService.RemoveVideoFromWatchlist(_selectedWatchlistId, videoId);
            _selectedWatchlistVideoIds.Remove(videoId);
        }
        else
        {
            await TabService.AddVideoToWatchlist(_selectedWatchlistId, videoId);
            _selectedWatchlistVideoIds.Add(videoId);
        }

        WatchlistTabs = TabService.GetWatchlistTabs();
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        _videoItems = await VideoService.GetVideoItems();
        var setting = await SettingService.GetSetting("TagBlacklist");
        if (setting != null)
            _globalBlackList = JsonConvert.DeserializeObject<List<string>>(setting.Value) ?? new List<string>();

        await LoadVideos();
        await LoadTags();
        await LoadActresses();
        WatchlistTabs = TabService.GetWatchlistTabs();
        AvailableSites = ScraperRegistry.GetEnabledSiteNames().ToList();
        RestoreFiltersFromUrl();
        _isLoading = false;
    }

