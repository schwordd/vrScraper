    private async void HandleImageError(Microsoft.AspNetCore.Components.Web.ErrorEventArgs e, DbVideoItem item)
    {
        // ErrorEventArgs hat keine CurrentTarget-Eigenschaft
        // Stattdessen setzen wir den Thumbnail-Pfad direkt im item-Objekt
        item.Thumbnail = "/images/thumbnail-not-available.svg";
        item.IsThumbnailNotAvailable = true;

        // Erhöhe den ErrorCount in der Datenbank und im Speicher
        await VideoService.UpdateVideoErrorCount(item.Id);

        StateHasChanged();
    }

    private async Task DownloadVideo(DbVideoItem item)
    {
        try
        {
            // Verwende den Backend-Download-Endpoint mit direktem Download
            var downloadUrl = $"/api/VideoProxy/download/{item.Id}";

            // Erstelle einen sicheren Dateinamen
            var safeTitle = System.Text.RegularExpressions.Regex.Replace(item.Title ?? "video", @"[^a-zA-Z0-9_-]", "_");
            var fileName = $"{safeTitle}_{item.SiteVideoId}.mp4";

            // Triggere Download über JavaScript
            await JSRuntime.InvokeVoidAsync("downloadFile", downloadUrl, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error downloading video: {ex.Message}");
        }
    }

    private DotNetObjectReference<Videos>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("addPageKeyListener", _dotNetRef);
            _urlSyncReady = true;
        }
    }

    [JSInvokable]
    public void HandleKeyNavigation(int direction)
    {
        if (direction == -1 && !IsFirstPage)
        {
            GoToPage(CurrentPage - 1);
            StateHasChanged();
        }
        if (direction == 1 && !IsLastPage)
        {
            GoToPage(CurrentPage + 1);
            StateHasChanged();
        }
    }

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalHours >= 1)
            return $"{(int)d.TotalHours}:{d.Minutes:D2}:{d.Seconds:D2}";
        return $"{d.Minutes}:{d.Seconds:D2}";
    }

