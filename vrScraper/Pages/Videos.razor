    // --- URL Sync ---
    private bool _urlSyncReady = false;

    private void RestoreFiltersFromUrl()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.Count == 0) return;

        if (query.TryGetValue("q", out var q)) _searchQuery = q.ToString();
        if (query.TryGetValue("sort", out var sort)) _currentSortOption = sort.ToString();
        if (query.TryGetValue("tags", out var tags) && !string.IsNullOrEmpty(tags))
        {
            _selectedTags = tags.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
            SelectedTags = _selectedTags.ToHashSet();
        }
        if (query.TryGetValue("actresses", out var actresses) && !string.IsNullOrEmpty(actresses))
        {
            _selectedActresses = actresses.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
            SelectedActresses = _selectedActresses.ToHashSet();
        }
        if (query.TryGetValue("sites", out var sites) && !string.IsNullOrEmpty(sites))
            _selectedSites = sites.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
        if (query.TryGetValue("liked", out var liked)) _showOnlyLiked = liked == "1";
        if (query.TryGetValue("unwatched", out var unwatched)) _showOnlyUnwatched = unwatched == "1";
        if (query.TryGetValue("errors", out var errors)) _showOnlyWithErrors = errors == "1";
        if (query.TryGetValue("page", out var page) && int.TryParse(page, out var p)) CurrentPage = p;
        if (query.TryGetValue("pageSize", out var ps) && int.TryParse(ps, out var psi)) PageSize = psi;
        if (query.TryGetValue("minDur", out var minD) && int.TryParse(minD, out var minDi)) _minDurationMinutes = minDi;
        if (query.TryGetValue("maxDur", out var maxD) && int.TryParse(maxD, out var maxDi)) _maxDurationMinutes = maxDi;
    }

    private void SyncUrlState()
    {
        if (!_urlSyncReady) return;

        var queryParams = new Dictionary<string, string?>();
        if (!string.IsNullOrEmpty(_searchQuery)) queryParams["q"] = _searchQuery;
        if (_currentSortOption != "latest") queryParams["sort"] = _currentSortOption;
        if (_selectedTags.Any()) queryParams["tags"] = string.Join(",", _selectedTags);
        if (_selectedActresses.Any()) queryParams["actresses"] = string.Join(",", _selectedActresses);
        if (_selectedSites.Any()) queryParams["sites"] = string.Join(",", _selectedSites);
        if (_showOnlyLiked) queryParams["liked"] = "1";
        if (_showOnlyUnwatched) queryParams["unwatched"] = "1";
        if (_showOnlyWithErrors) queryParams["errors"] = "1";
        if (CurrentPage > 1) queryParams["page"] = CurrentPage.ToString();
        if (PageSize != 30) queryParams["pageSize"] = PageSize.ToString();
        if (_minDurationMinutes > 0) queryParams["minDur"] = _minDurationMinutes.ToString();
        if (_maxDurationMinutes > 0 && _maxDurationMinutes < DurationSliderMax) queryParams["maxDur"] = _maxDurationMinutes.ToString();

        var url = Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/videos", queryParams);
        NavigationManager.NavigateTo(url, replace: true, forceLoad: false);
    }
