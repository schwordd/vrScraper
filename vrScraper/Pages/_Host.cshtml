@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@attribute [AllowAnonymous]
@namespace vrScraper.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
  <title>VRScraper</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cross-Origin-Opener-Policy" content="same-origin" />
    <meta http-equiv="Cross-Origin-Embedder-Policy" content="require-corp" />
    <base href="~/" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static/font/lucide.min.css" />
    <link rel="stylesheet" href="css/site.css" />
    <link rel="stylesheet" href="css/design-tokens.css" />
    <link rel="stylesheet" href="css/components.css" />
    <link rel="stylesheet" href="css/layout.css" />
    <link href="vrScraper.styles.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />

    <!-- VideoJS CSS -->
    <link href="https://unpkg.com/video.js@8.10.0/dist/video-js.min.css" rel="stylesheet" />

    <!-- VideoJS VR Plugin CSS -->
    <link href="https://unpkg.com/videojs-vr@2.0.0/dist/videojs-vr.css" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">&#x2715;</a>
    </div>

    <script src="_framework/blazor.server.js"></script>

    <!-- VideoJS -->
    <script src="https://unpkg.com/video.js@8.10.0/dist/video.min.js"></script>

    <!-- Three.js (benötigt für videojs-vr) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>

    <!-- VideoJS VR Plugin -->
    <script src="https://unpkg.com/videojs-vr@2.0.0/dist/videojs-vr.min.js"></script>

    <!-- Unser eigenes JS -->
    <script src="~/js/videoPlayer.js"></script>
    <script src="~/js/download.js"></script>
    <script src="~/js/pageKeyNavigation.js"></script>
    <script src="~/js/auth.js"></script>

    <!-- SortableJS for drag-and-drop -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script src="~/js/tabSortable.js"></script>
</body>
</html>
