@page "/"

@using vrScraper.Components
@using vrScraper.DB.Models
@using vrScraper.Services
@using vrScraper.Services.Interfaces
@inject IVideoService VideoService
@inject IScrapeLogService ScrapeLogService
@inject IDailySnapshotService DailySnapshotService

<h3>Home</h3>

<div class="row">
    <div class="col-12">
        <div class="vr-panel p-3 mb-3">
            <ScrapingTools />
        </div>
    </div>
</div>

<div class="dashboard-overview">
    <div class="stats-col">
        <div class="stat-item">
            <i class="icon-film stat-icon"></i>
            <div class="stat-value">@TotalVideos.ToString("N0")</div>
            <div class="stat-label">Total Videos</div>
        </div>
        <div class="stat-item">
            <i class="icon-eye stat-icon"></i>
            <div class="stat-value">@WatchedVideos.ToString("N0")</div>
            <div class="stat-label">Watched</div>
        </div>
        <div class="stat-item">
            <i class="icon-eye-off stat-icon"></i>
            <div class="stat-value">@UnwatchedVideos.ToString("N0")</div>
            <div class="stat-label">Unwatched</div>
        </div>
        <div class="stat-item">
            <i class="icon-play stat-icon"></i>
            <div class="stat-value">@TotalWatchTime</div>
            <div class="stat-label">Watch Time</div>
        </div>
        <div class="stat-item">
            <i class="icon-heart stat-icon"></i>
            <div class="stat-value">@LikedVideos.ToString("N0")</div>
            <div class="stat-label">Liked</div>
        </div>
        <div class="stat-item">
            <i class="icon-rotate-ccw stat-icon"></i>
            <div class="stat-value">@TotalPlays.ToString("N0")</div>
            <div class="stat-label">Total Plays</div>
        </div>
        <div class="stat-item">
            <i class="icon-clock stat-icon"></i>
            <div class="stat-value">@LibrarySize</div>
            <div class="stat-label">Library Size</div>
        </div>
        <div class="stat-item">
            <i class="icon-sparkles stat-icon"></i>
            <div class="stat-value">@EnrichedPercent</div>
            <div class="stat-label">Enriched</div>
        </div>
    </div>
    <div class="chart-col">
        <PieChart Title="Videos by Source"
                  Data="@_sourceDistribution"
                  Colors="@_sourceColors" />
    </div>
</div>

<div class="collapsible-section">
    <h5 class="collapsible-header" @onclick="() => _tasteOpen = !_tasteOpen">
        <i class="@(_tasteOpen ? "icon-chevron-down" : "icon-chevron-right")"></i>
        Taste Profile
    </h5>
    @if (_tasteOpen)
    {
        <TasteProfile />
    }
</div>

<div class="collapsible-section">
    <h5 class="collapsible-header" @onclick="() => _leaderboardOpen = !_leaderboardOpen">
        <i class="@(_leaderboardOpen ? "icon-chevron-down" : "icon-chevron-right")"></i>
        Actress Leaderboard
    </h5>
    @if (_leaderboardOpen)
    {
        <ActressLeaderboard />
    }
</div>

<div class="row mt-0 g-2">
    <div class="col-md-6">
        <div class="collapsible-section">
            <h5 class="collapsible-header" @onclick="() => _tagsOpen = !_tagsOpen">
                <i class="@(_tagsOpen ? "icon-chevron-down" : "icon-chevron-right")"></i>
                Tags
            </h5>
            @if (_tagsOpen)
            {
                <TagOverview />
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="collapsible-section">
            <h5 class="collapsible-header" @onclick="() => _actorsOpen = !_actorsOpen">
                <i class="@(_actorsOpen ? "icon-chevron-down" : "icon-chevron-right")"></i>
                Actresses
            </h5>
            @if (_actorsOpen)
            {
                <ActorOverview />
            }
        </div>
    </div>
</div>

@if (_recentLogs.Count > 0)
{
    <div class="collapsible-section">
        <h5 class="collapsible-header" @onclick="() => _scrapeLogOpen = !_scrapeLogOpen">
            <i class="@(_scrapeLogOpen ? "icon-chevron-down" : "icon-chevron-right")"></i>
            Recent Scraping Runs
        </h5>
        @if (_scrapeLogOpen)
        {
            <div class="table-responsive">
                <table class="scrape-log-table">
                    <thead>
                        <tr>
                            <th>Site</th>
                            <th>Trigger</th>
                            <th>Started</th>
                            <th>Duration</th>
                            <th>Pages</th>
                            <th>New</th>
                            <th>Dupes</th>
                            <th>Errors</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in _recentLogs)
                        {
                            <tr>
                                <td>@log.Site</td>
                                <td>@log.TriggerType</td>
                                <td>@log.StartedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@FormatLogDuration(log)</td>
                                <td>@log.PagesScraped</td>
                                <td>@log.NewVideos</td>
                                <td>@log.DuplicatesSkipped</td>
                                <td>@log.Errors</td>
                                <td><span class="log-status log-status-@log.Status.ToLowerInvariant()">@log.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

<div class="vr-panel p-3 mb-3">
    <DailyTrendChart Data="_trendData" Title="Library trend (last 30 days)" />
</div>

@code {
    private int TotalVideos;
    private int WatchedVideos;
    private int UnwatchedVideos;
    private string TotalWatchTime = "0h 0m";
    private int LikedVideos;
    private long TotalPlays;
    private string LibrarySize = "0h";
    private string EnrichedPercent = "0%";

    private List<DbScrapeLog> _recentLogs = new();
    private List<DbDailySnapshot> _trendData = new();
    private bool _tasteOpen = false;
    private bool _leaderboardOpen = false;
    private bool _scrapeLogOpen = false;
    private bool _tagsOpen = false;
    private bool _actorsOpen = false;

    private Dictionary<string, int> _sourceDistribution = new();
    private Dictionary<string, string> _sourceColors = new()
    {
        { "eporner.com", "#d97706" },
        { "xhamster.com", "#0284c7" },
        { "spankbang.com", "#e11d48" }
    };

    protected override async Task OnInitializedAsync()
    {
        var videos = await VideoService.GetVideoItems();

        // Single-pass aggregation. Eight separate LINQ scans over the in-memory list
        // were noticeably slow on large libraries; one foreach is the same answer in 1/8th the work.
        int total = 0, watched = 0, liked = 0, parsedCount = 0;
        long totalPlays = 0;
        long playDurationTicks = 0;
        long durationTicks = 0;
        var siteCounts = new Dictionary<string, int>();
        foreach (var v in videos)
        {
            total++;
            if (v.PlayCount > 0) watched++;
            if (v.Liked) liked++;
            if (v.ParsedDetails) parsedCount++;
            totalPlays += v.PlayCount;
            playDurationTicks += v.PlayDurationEst.Ticks;
            durationTicks += v.Duration.Ticks;
            var site = v.Site ?? "unknown";
            siteCounts[site] = siteCounts.GetValueOrDefault(site) + 1;
        }

        TotalVideos = total;
        WatchedVideos = watched;
        UnwatchedVideos = total - watched;
        LikedVideos = liked;
        TotalPlays = totalPlays;

        var totalDuration = TimeSpan.FromTicks(playDurationTicks);
        TotalWatchTime = $"{(int)totalDuration.TotalHours}h {totalDuration.Minutes}m";

        var libDuration = TimeSpan.FromTicks(durationTicks);
        LibrarySize = $"{(int)libDuration.TotalHours:N0}h";

        EnrichedPercent = total > 0
            ? $"{(double)parsedCount / total * 100:F0}%"
            : "0%";

        _sourceDistribution = siteCounts;

        _recentLogs = await ScrapeLogService.GetRecentLogs(10);
        _trendData = await DailySnapshotService.GetLastSnapshots(30);
    }

    private static string FormatLogDuration(DbScrapeLog log)
    {
        if (!log.FinishedUtc.HasValue) return "...";
        var d = log.FinishedUtc.Value - log.StartedUtc;
        if (d.TotalHours >= 1) return $"{(int)d.TotalHours}h {d.Minutes}m";
        if (d.TotalMinutes >= 1) return $"{(int)d.TotalMinutes}m {d.Seconds}s";
        return $"{(int)d.TotalSeconds}s";
    }
}
