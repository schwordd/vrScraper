@page "/settings"

@using Newtonsoft.Json
@using System.Text.RegularExpressions
@using vrScraper.DB.Models
@using vrScraper.Components
@using vrScraper.Services

@using Microsoft.AspNetCore.Identity
@inject IVideoService VideoService
@inject ISettingService SettingService
@inject IScraperRegistry ScraperRegistry

<h3>Settings</h3>

<div class="settings-container">

    <!-- Tag Blacklist Section -->
    <div class="settings-section">
        <h5 class="section-title">
            <i class="icon-ban me-2"></i>
            Content Filtering
        </h5>

        <div class="setting-card">
            <label class="form-label fw-semibold mb-3">
                <i class="icon-filter me-1"></i>
                Global Tag Blacklist
            </label>
            <MultiSelect IsMultiple="true" TItem="DbTag" Data="@AvailableTags"
                             TextField="@((item) => item.Name)"
                             ValueField="@((item) => item.Name)"
                             ShowSearch="true"
                             @bind-SelectedValues="TagBlacklist" />
            <small class="form-text text-muted mt-2">
                Select tags that should be filtered out from all video listings and API responses
            </small>
        </div>

    </div>

    <!-- Per-Site Configuration -->
    <div class="settings-section">
        <h5 class="section-title">
            <i class="icon-globe me-2"></i>
            Source Sites
        </h5>
        <div class="table-responsive">
            <table class="vr-table">
                <thead>
                    <tr>
                        <th>Site</th>
                        <th>Enabled</th>
                        <th>Min Duration (sec)</th>
                        <th>Auto-Scrape</th>
                        <th>Scrape Time (HH:MM)</th>
                        <th>Max Pages</th>
                        <th>Auto-Enrich</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var scraper in ScraperRegistry.GetAllScrapers())
                    {
                        var s = scraper.SiteName;
                        var isEnabled = !scraper.IsExperimental && GetSiteSetting(s, "Enabled", s == "eporner.com" ? "true" : "false") == "true";
                        var minDur = GetSiteSetting(s, "MinDuration", "0");
                        var autoEnabled = GetSiteSetting(s, "AutoScrapeEnabled", "false") == "true";
                        var autoTime = GetSiteSetting(s, "AutoScrapeTime", "02:00");
                        var autoMaxPages = GetSiteSetting(s, "AutoScrapeMaxPages", "50");
                        var autoEnrichEnabled = GetSiteSetting(s, "AutoEnrichEnabled", "true") == "true";
                        <tr class="@(!isEnabled ? "site-disabled" : "")">
                            <td>
                                <span class="fw-semibold">@scraper.DisplayName</span>
                                @if (scraper.IsExperimental)
                                {
                                    <span class="badge bg-warning text-dark ms-2">Experimental</span>
                                }
                            </td>
                            <td>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" checked="@isEnabled"
                                           disabled="@scraper.IsExperimental"
                                           @onchange="(e) => OnSiteCheckboxChanged(s, nameof(isEnabled), e)" />
                                </div>
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm site-input-sm" min="0" max="3600"
                                       value="@minDur" @onchange="(e) => OnSiteInputChanged(s, nameof(minDur), e)" />
                            </td>
                            <td>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" checked="@autoEnabled"
                                           @onchange="(e) => OnSiteCheckboxChanged(s, nameof(autoEnabled), e)" />
                                </div>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm site-input-sm" placeholder="HH:MM"
                                       value="@autoTime" @onchange="(e) => OnSiteTimeChanged(s, e)" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm site-input-sm" min="1" max="500"
                                       value="@autoMaxPages" @onchange="(e) => OnSiteInputChanged(s, nameof(autoMaxPages), e)" />
                            </td>
                            <td>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" checked="@autoEnrichEnabled"
                                           @onchange="(e) => OnSiteCheckboxChanged(s, nameof(autoEnrichEnabled), e)" />
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Change Password Section -->
    <div class="settings-section">
        <h5 class="section-title">
            <i class="icon-lock me-2"></i>
            Change Password
        </h5>

        <div class="settings-grid">
            <div class="setting-card password-card">
                <div class="password-form">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="icon-key me-1"></i>
                            Current Password
                        </label>
                        <input type="password" class="form-control" @bind="_oldPassword" placeholder="Enter current password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="icon-lock me-1"></i>
                            New Password
                        </label>
                        <input type="password" class="form-control" @bind="_newPassword" placeholder="Enter new password (min. 4 characters)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="icon-lock me-1"></i>
                            Confirm New Password
                        </label>
                        <input type="password" class="form-control" @bind="_confirmNewPassword" placeholder="Confirm new password" />
                    </div>
                    <button class="btn btn-primary" @onclick="ChangePassword" disabled="@_changingPassword">
                        @if (_changingPassword)
                        {
                            <span>Saving...</span>
                        }
                        else
                        {
                            <i class="icon-save me-1"></i>
                            <span>Save Password</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(_passwordMessage))
                    {
                        <div class="mt-3 alert @(_passwordSuccess ? "alert-success" : "alert-danger") py-2">
                            @_passwordMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

</div>

@code {
    private List<DbTag> AvailableTags { get; set; } = new();
    private List<DbSetting> AllSettings { get; set; } = new();

    public IEnumerable<string> TagBlacklist
    {
        get
        {
            var s = AllSettings.FirstOrDefault(s => s.Key == "TagBlacklist");
            if (s == null) return Enumerable.Empty<string>();
            return JsonConvert.DeserializeObject<List<string>>(s.Value ?? "[]") ?? new List<string>();
        }

        set
        {
            var s = AllSettings.FirstOrDefault(s => s.Key == "TagBlacklist");
            if (s == null) return;
            s.Value = JsonConvert.SerializeObject(value);
            this.SettingService.UpdateSetting(s);
        }
    }

    private string GetSiteSetting(string site, string key, string defaultValue)
    {
        var settingKey = $"Site:{site}:{key}";
        var s = AllSettings.FirstOrDefault(s => s.Key == settingKey);
        return s?.Value ?? defaultValue;
    }

    private void SetSiteSetting(string site, string key, string value)
    {
        var settingKey = $"Site:{site}:{key}";
        var s = AllSettings.FirstOrDefault(s => s.Key == settingKey);
        if (s == null)
        {
            s = new DbSetting { Key = settingKey, Type = "System.String", Value = value };
            AllSettings.Add(s);
        }
        s.Value = value;
        SettingService.UpdateSetting(s);
        StateHasChanged();
    }

    private void OnSiteCheckboxChanged(string site, string field, ChangeEventArgs e)
    {
        var key = field switch
        {
            nameof(Boolean) => "Enabled",
            "isEnabled" => "Enabled",
            "autoEnabled" => "AutoScrapeEnabled",
            "autoEnrichEnabled" => "AutoEnrichEnabled",
            _ => field
        };
        SetSiteSetting(site, key, e.Value?.ToString()?.ToLowerInvariant() ?? "false");
    }

    private void OnSiteInputChanged(string site, string field, ChangeEventArgs e)
    {
        var key = field switch
        {
            "minDur" => "MinDuration",
            "autoMaxPages" => "AutoScrapeMaxPages",
            _ => field
        };
        SetSiteSetting(site, key, e.Value?.ToString() ?? "");
    }

    private void OnSiteTimeChanged(string site, ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        if (!Regex.IsMatch(value, @"^([01]\d|2[0-3]):[0-5]\d$"))
            return;
        SetSiteSetting(site, "AutoScrapeTime", value);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTags();
        await LoadSettings();
    }

    private async Task LoadTags()
    {
        AvailableTags = (await VideoService.GetTagInfos()).Select(x => x.Tag).ToList();
    }

    private async Task LoadSettings()
    {
        AllSettings = (await SettingService.GetAllSettings()).ToList();
    }

    // Password change fields
    private static readonly PasswordHasher<string> _hasher = new();
    private string _oldPassword = "";
    private string _newPassword = "";
    private string _confirmNewPassword = "";
    private bool _changingPassword;
    private string? _passwordMessage;
    private bool _passwordSuccess;

    private async Task ChangePassword()
    {
        _passwordMessage = null;
        _passwordSuccess = false;

        if (string.IsNullOrWhiteSpace(_oldPassword))
        {
            _passwordMessage = "Please enter your current password.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 4)
        {
            _passwordMessage = "New password must be at least 4 characters.";
            return;
        }

        if (_newPassword != _confirmNewPassword)
        {
            _passwordMessage = "New passwords do not match.";
            return;
        }

        _changingPassword = true;
        try
        {
            var setting = await SettingService.GetSetting("AuthPasswordHash");
            var hash = setting?.Value ?? "";
            if (string.IsNullOrEmpty(hash))
            {
                _passwordMessage = "No password set. Please use the initial setup.";
                return;
            }

            var result = _hasher.VerifyHashedPassword("admin", hash, _oldPassword);
            if (result == PasswordVerificationResult.Failed)
            {
                _passwordMessage = "Wrong current password.";
                return;
            }

            var newHash = _hasher.HashPassword("admin", _newPassword);
            await SettingService.SaveSetting("AuthPasswordHash", newHash);

            _passwordSuccess = true;
            _passwordMessage = "Password changed successfully.";
            _oldPassword = "";
            _newPassword = "";
            _confirmNewPassword = "";
        }
        catch
        {
            _passwordMessage = "An error occurred while changing the password.";
        }
        finally
        {
            _changingPassword = false;
        }
    }
}
