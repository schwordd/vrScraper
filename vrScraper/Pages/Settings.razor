@page "/settings"

@using System.Text.Json
@using System.Text.RegularExpressions
@using vrScraper.DB.Models
@using Blzr.BootstrapSelect
@using vrScraper.Services

@inject IVideoService VideoService
@inject ISettingService SettingService
@inject IScraperRegistry ScraperRegistry

<h3>Settings</h3>

<div class="settings-container">

    <!-- Tag Blacklist Section -->
    <div class="settings-section">
        <h5 class="section-title">
            <i class="fas fa-ban me-2"></i>
            Content Filtering
        </h5>

        <div class="setting-card">
            <label class="form-label fw-semibold mb-3">
                <i class="fas fa-filter me-1"></i>
                Global Tag Blacklist
            </label>
            <BootstrapSelect IsMultiple="true" TItem="DbTag" Data="@AvailableTags"
                             TextField="@((item) => item.Name)"
                             ValueField="@((item) => item.Name)"
                             ShowSearch="true"
                             TType="IEnumerable<string>"
                             @bind-Value="TagBlacklist" />
            <small class="form-text text-muted mt-2">
                Select tags that should be filtered out from all video listings and API responses
            </small>
        </div>

    </div>

    <!-- Per-Site Configuration -->
    @foreach (var scraper in ScraperRegistry.GetAllScrapers())
    {
        var site = scraper.SiteName;
        <div class="settings-section">
            <h5 class="section-title">
                <i class="fas fa-globe me-2"></i>
                @scraper.DisplayName
                <span class="badge @(GetSiteSetting(site, "Enabled", "true") == "true" ? "bg-success" : "bg-secondary") ms-2" style="font-size: 11px;">
                    @(GetSiteSetting(site, "Enabled", "true") == "true" ? "Active" : "Disabled")
                </span>
            </h5>

            @{
                var s = site;
                var isEnabled = GetSiteSetting(s, "Enabled", "true") == "true";
                var minDur = GetSiteSetting(s, "MinDuration", "0");
                var autoEnabled = GetSiteSetting(s, "AutoScrapeEnabled", "false") == "true";
                var autoTime = GetSiteSetting(s, "AutoScrapeTime", "02:00");
                var autoMaxPages = GetSiteSetting(s, "AutoScrapeMaxPages", "50");
            }
            <div class="settings-grid">
                <div class="setting-card">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               checked="@isEnabled"
                               @onchange="(e) => OnSiteCheckboxChanged(s, nameof(isEnabled), e)" />
                        <label class="form-check-label fw-semibold">Enabled</label>
                    </div>
                    <small class="text-muted">Show videos from this source</small>
                </div>

                <div class="setting-card">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-hourglass-half me-1"></i>
                        Min. Duration (seconds)
                    </label>
                    <input type="number" class="form-control" min="0" max="3600"
                           value="@minDur"
                           @onchange="(e) => OnSiteInputChanged(s, nameof(minDur), e)" />
                    <small class="text-muted">0 = no filter</small>
                </div>

                <div class="setting-card">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               checked="@autoEnabled"
                               @onchange="(e) => OnSiteCheckboxChanged(s, nameof(autoEnabled), e)" />
                        <label class="form-check-label fw-semibold">Auto-Scrape</label>
                    </div>
                    <small class="text-muted">Include in daily automated scraping</small>
                </div>

                <div class="setting-card">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-clock me-1"></i>
                        Scrape Time
                    </label>
                    <input type="text" class="form-control" placeholder="HH:MM"
                           value="@autoTime"
                           @onchange="(e) => OnSiteTimeChanged(s, e)" />
                </div>

                <div class="setting-card">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-file-alt me-1"></i>
                        Max Pages
                    </label>
                    <input type="number" class="form-control" min="1" max="500"
                           value="@autoMaxPages"
                           @onchange="(e) => OnSiteInputChanged(s, nameof(autoMaxPages), e)" />
                </div>
            </div>
        </div>
    }

    <!-- Recommendations Settings -->
    <div class="settings-section">
        <h5 class="section-title">
            <i class="fas fa-thumbs-up me-2"></i>
            Recommendations
        </h5>

        <div class="settings-grid">
            <div class="setting-card">
                <div class="setting-header">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="recommendationsEnabled" @bind="RecommendationsEnabled" />
                        <label class="form-check-label fw-semibold" for="recommendationsEnabled">
                            Enable Recommendations
                        </label>
                    </div>
                </div>
                <small class="text-muted">
                    Show a Recommended tab with personalized video suggestions based on your likes and watch history
                </small>
            </div>
        </div>
    </div>

</div>

@code {
    private List<DbTag> AvailableTags { get; set; } = new();
    private List<DbSetting> AllSettings { get; set; } = new();

    public IEnumerable<string> TagBlacklist
    {
        get
        {
            var s = AllSettings.Single(s => s.Key == "TagBlacklist");
            return JsonSerializer.Deserialize<List<string>>(s.Value)!;
        }

        set
        {
            var s = AllSettings.Single(s => s.Key == "TagBlacklist");
            s.Value = JsonSerializer.Serialize(value);
            this.SettingService.UpdateSetting(s);
        }
    }

    public bool RecommendationsEnabled
    {
        get
        {
            var s = AllSettings.FirstOrDefault(s => s.Key == "RecommendationsEnabled");
            return s != null && bool.TryParse(s.Value, out bool result) && result;
        }
        set
        {
            var s = AllSettings.FirstOrDefault(s => s.Key == "RecommendationsEnabled");
            if (s == null) return;
            s.Value = value.ToString();
            this.SettingService.UpdateSetting(s);
        }
    }

    private string GetSiteSetting(string site, string key, string defaultValue)
    {
        var settingKey = $"Site:{site}:{key}";
        var s = AllSettings.FirstOrDefault(s => s.Key == settingKey);
        return s?.Value ?? defaultValue;
    }

    private void SetSiteSetting(string site, string key, string value)
    {
        var settingKey = $"Site:{site}:{key}";
        var s = AllSettings.FirstOrDefault(s => s.Key == settingKey);
        if (s == null)
        {
            s = new DbSetting { Key = settingKey, Type = "System.String", Value = value };
            AllSettings.Add(s);
        }
        s.Value = value;
        SettingService.UpdateSetting(s);
        StateHasChanged();
    }

    private void OnSiteCheckboxChanged(string site, string field, ChangeEventArgs e)
    {
        var key = field switch
        {
            nameof(Boolean) => "Enabled",
            "isEnabled" => "Enabled",
            "autoEnabled" => "AutoScrapeEnabled",
            _ => field
        };
        SetSiteSetting(site, key, e.Value?.ToString() ?? "false");
    }

    private void OnSiteInputChanged(string site, string field, ChangeEventArgs e)
    {
        var key = field switch
        {
            "minDur" => "MinDuration",
            "autoMaxPages" => "AutoScrapeMaxPages",
            _ => field
        };
        SetSiteSetting(site, key, e.Value?.ToString() ?? "");
    }

    private void OnSiteTimeChanged(string site, ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        if (!Regex.IsMatch(value, @"^([01]\d|2[0-3]):[0-5]\d$"))
            return;
        SetSiteSetting(site, "AutoScrapeTime", value);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTags();
        await LoadSettings();
    }

    private async Task LoadTags()
    {
        AvailableTags = (await VideoService.GetTagInfos()).Select(x => x.Tag).ToList();
    }

    private async Task LoadSettings()
    {
        AllSettings = (await SettingService.GetAllSettings()).ToList();
    }
}
