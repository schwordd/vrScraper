@page "/enrichment"

@using vrScraper.Services
@using vrScraper.DB
@using Microsoft.EntityFrameworkCore

@inject ITitleNormalizationService TitleNormService
@inject IThePornDbService ThePornDbService
@inject ISettingService SettingService
@inject IServiceProvider ServiceProvider
@inject IVideoService VideoService

<h3>Data Enrichment</h3>

<div class="enrichment-container">

    <!-- Reset Section -->
    <div class="enrichment-section">
        <h5 class="section-title">
            <i class="icon-trash-2 me-2"></i>
            Reset Enrichment Data
        </h5>
        <p class="section-desc">
            Removes all auto-detected data (NormalizedTitle, auto-detected stars/tags) so you can re-run enrichment from scratch.
        </p>
        <div class="action-controls">
            <button class="btn btn-danger" @onclick="ResetEnrichmentData" disabled="@_resetRunning">
                @if (_resetRunning)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="icon-rotate-ccw me-1"></i> Reset All Enrichment Data
            </button>
            @if (_resetResult != null)
            {
                <span class="text-success ms-2">@_resetResult</span>
            }
        </div>
    </div>

    <!-- Title Normalization Section -->
    <div class="enrichment-section">
        <h5 class="section-title">
            <i class="icon-languages me-2"></i>
            Title Normalization
        </h5>
        <p class="section-desc">
            Decodes obfuscated video titles (Unicode tricks, leet-speak) and detects stars/tags from all titles.
        </p>

        <div class="action-row">
            <div class="action-card">
                <div class="action-header">
                    <h6>Normalize &amp; Detect</h6>
                    <small class="text-muted">Normalizes obfuscated titles + detects stars/tags from all video titles</small>
                </div>
                <div class="action-controls">
                    <label class="form-check">
                        <input type="checkbox" class="form-check-input" @bind="_normTitles" />
                        <span class="form-check-label">Titles</span>
                    </label>
                    <label class="form-check">
                        <input type="checkbox" class="form-check-input" @bind="_normStars" />
                        <span class="form-check-label">Stars</span>
                    </label>
                    <label class="form-check">
                        <input type="checkbox" class="form-check-input" @bind="_normTags" />
                        <span class="form-check-label">Tags</span>
                    </label>
                    <label class="form-check">
                        <input type="checkbox" class="form-check-input" @bind="_forceReprocess" />
                        <span class="form-check-label">Force reprocess</span>
                    </label>
                    <button class="btn btn-primary" @onclick="RunNormalization" disabled="@(_normRunning || (!_normTitles && !_normStars && !_normTags))">
                        @if (_normRunning)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="icon-wand-sparkles me-1"></i> Run Normalization
                    </button>
                </div>
                @if (_normRunning || _normResult != null)
                {
                    <div class="progress-section">
                        @if (_normRunning && _normProgress != null)
                        {
                            <div class="progress mb-2">
                                <div class="progress-bar" role="progressbar"
                                     style="width: @(_normProgress.Total > 0 ? (int)(_normProgress.Current * 100.0 / _normProgress.Total) : 0)%">
                                    @_normProgress.Current / @_normProgress.Total
                                </div>
                            </div>
                            <div class="stats-row">
                                <span class="stat-badge"><i class="icon-activity me-1"></i>@_normProgress.Phase</span>
                                <span class="stat-badge"><i class="icon-type me-1"></i>@_normProgress.TitlesNormalized titles decoded</span>
                                <span class="stat-badge"><i class="icon-user me-1"></i>@_normProgress.StarsDetected stars detected</span>
                                <span class="stat-badge"><i class="icon-tag me-1"></i>@_normProgress.TagsDetected tags detected</span>
                            </div>
                        }
                        @if (_normResult != null)
                        {
                            <div class="alert @(_normSuccess ? "alert-success" : "alert-danger") mt-2 mb-0">
                                @_normResult
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

