@code {
    private bool _forceReprocess;
    private bool _normTitles = true;
    private bool _normStars;
    private bool _normTags;

    // Normalization state
    private bool _normRunning;
    private NormalizationProgress? _normProgress;
    private string? _normResult;
    private bool _normSuccess;

    // Enrichment state
    private bool _enrichRunning;
    private int _enrichCurrent;
    private int _enrichTotal;
    private string? _enrichResult;
    private bool _enrichSuccess;

    // Reset state
    private bool _resetRunning;
    private string? _resetResult;

    // API token
    private string _apiToken = "";
    private bool _showToken;
    private bool _tokenSaved;

    protected override void OnInitialized()
    {
        _apiToken = SettingService.GetSettingValue("ThePornDbApiToken") ?? "";
    }

    private async Task ResetEnrichmentData()
    {
        _resetRunning = true;
        _resetResult = null;
        StateHasChanged();

        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<VrScraperContext>();

            await context.Database.ExecuteSqlRawAsync(
                "DELETE FROM VideoStars WHERE IsAutoDetected = 1");
            await context.Database.ExecuteSqlRawAsync(
                "DELETE FROM VideoTags WHERE IsAutoDetected = 1");
            int count = await context.Database.ExecuteSqlRawAsync(
                "UPDATE VideoItems SET NormalizedTitle = NULL WHERE NormalizedTitle IS NOT NULL");

            await VideoService.ReloadVideos();
            _resetResult = $"Reset {count} videos.";
        }
        catch (Exception ex)
        {
            _resetResult = $"Error: {ex.Message}";
        }
        finally
        {
            _resetRunning = false;
            StateHasChanged();
        }
    }

    private async Task RunNormalization()
    {
        _normRunning = true;
        _normResult = null;
        _normProgress = new NormalizationProgress();
        StateHasChanged();

        using var cts = new CancellationTokenSource();
        _ = RefreshUiPeriodically(cts.Token);

        try
        {
            var count = await TitleNormService.NormalizeAllTitles(_forceReprocess, _normTitles, _normStars, _normTags, _normProgress);
            _normResult = $"Done! Processed {count} videos. " +
                $"Decoded {_normProgress.TitlesNormalized} titles, " +
                $"detected {_normProgress.StarsDetected} stars, " +
                $"{_normProgress.TagsDetected} tags.";
            _normSuccess = true;
        }
        catch (Exception ex)
        {
            _normResult = $"Error: {ex.Message}";
            _normSuccess = false;
        }
        finally
        {
            _normRunning = false;
            cts.Cancel();
            StateHasChanged();
        }
    }

    private async Task SaveApiToken()
    {
        await SettingService.SaveSetting("ThePornDbApiToken", _apiToken);
        _tokenSaved = true;
        StateHasChanged();
        await Task.Delay(2000);
        _tokenSaved = false;
        StateHasChanged();
    }

    private async Task RunEnrichment()
    {
        _enrichRunning = true;
        _enrichResult = null;
        _enrichCurrent = 0;
        _enrichTotal = 0;
        StateHasChanged();

        using var cts = new CancellationTokenSource();
        _ = RefreshUiPeriodically(cts.Token);

        try
        {
            var count = await ThePornDbService.EnrichAllStars((current, total) =>
            {
                _enrichCurrent = current;
                _enrichTotal = total;
            });
            _enrichResult = $"Done! Enriched {count} stars with additional tags.";
            _enrichSuccess = true;
        }
        catch (Exception ex)
        {
            _enrichResult = $"Error: {ex.Message}";
            _enrichSuccess = false;
        }
        finally
        {
            _enrichRunning = false;
            cts.Cancel();
            StateHasChanged();
        }
    }

    private async Task RefreshUiPeriodically(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(500, ct);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (ObjectDisposedException) { }
    }
}
