    <!-- Reset Section -->
    <div class="enrichment-section">
        <h5 class="section-title">
            <i class="icon-trash-2 me-2"></i>
            Reset Enrichment Data
        </h5>
        <p class="section-desc">
            Removes all auto-detected data (NormalizedTitle, auto-detected stars/tags) so you can re-run enrichment from scratch.
        </p>
        <div class="action-controls">
            <button class="btn btn-danger" @onclick="ResetEnrichmentData" disabled="@_resetRunning">
                @if (_resetRunning)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="icon-rotate-ccw me-1"></i> Reset All Enrichment Data
            </button>
            @if (_resetResult != null)
            {
                <span class="text-success ms-2">@_resetResult</span>
            }
        </div>
    </div>

</div>

@code {
    private bool _forceReprocess;
    private bool _normTitles = true;
    private bool _normStars = true;
    private bool _normTags = true;

    // Normalization state
    private bool _normRunning;
    private NormalizationProgress? _normProgress;
    private CancellationTokenSource? _normCts;

    // Reset state
    private bool _resetRunning;
    private string? _resetResult;

    // Log output
    private record LogEntry(DateTime Time, string Level, string Message);
    private List<LogEntry> _logLines = new();

    private void Log(string message, string level = "info")
    {
        _logLines.Add(new LogEntry(DateTime.Now, level, message));
    }

    private static string LogIcon(string level) => level switch
    {
        "ok" => "\u2705",
        "warn" => "\u26a0\ufe0f",
        "error" => "\u274c",
        "wait" => "\u23f3",
        _ => "\u2139\ufe0f"
    };


    private async Task ResetEnrichmentData()
    {
        _resetRunning = true;
        _resetResult = null;
        StateHasChanged();

        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<VrScraperContext>();

            await context.Database.ExecuteSqlRawAsync(
                "DELETE FROM VideoStars WHERE IsAutoDetected = 1");
            await context.Database.ExecuteSqlRawAsync(
                "DELETE FROM VideoTags WHERE IsAutoDetected = 1");
            int count = await context.Database.ExecuteSqlRawAsync(
                "UPDATE VideoItems SET NormalizedTitle = NULL WHERE NormalizedTitle IS NOT NULL");

            await VideoService.ReloadVideos();
            _resetResult = $"Reset {count} videos.";
        }
        catch (Exception ex)
        {
            _resetResult = $"Error: {ex.Message}";
        }
        finally
        {
            _resetRunning = false;
            StateHasChanged();
        }
    }

    private void CancelNormalization()
    {
        _normCts?.Cancel();
        Log("Cancellation requested...", "warn");
    }

    private async Task RunNormalization()
    {
        _normRunning = true;
        _normProgress = new NormalizationProgress();
        _logLines.Clear();
        _normCts = new CancellationTokenSource();
        StateHasChanged();

        using var refreshCts = new CancellationTokenSource();
        _ = RefreshUiPeriodically(refreshCts.Token);

        try
        {
            var ct = _normCts.Token;

            if (_normTitles)
            {
                Log("Starting decoder (234k words)...", "info");
            }

            var count = await TitleNormService.NormalizeAllTitles(
                _forceReprocess, _normTitles, _normStars, _normTags, _normProgress,
                onTitleProcessed: (original, normalized, status) =>
                {
                    var idx = _normProgress?.Current ?? 0;
                    var total = _normProgress?.Total ?? 0;
                    var shortOriginal = original.Length > 40 ? original[..40] + "..." : original;
                    var shortNormalized = normalized != null && normalized.Length > 40 ? normalized[..40] + "..." : normalized;

                    switch (status)
                    {
                        case "decoder":
                            Log($"[{idx}/{total}] \"{shortOriginal}\" → \"{shortNormalized}\"", "ok");
                            break;
                        case "decoder-unsicher":
                            Log($"[{idx}/{total}] \"{shortOriginal}\" → \"{shortNormalized}\" (uncertain)", "warn");
                            break;
                        default: // "skip"
                            Log($"[{idx}/{total}] \"{shortOriginal}\" → unchanged", "warn");
                            break;
                    }
                },
                ct: ct);

            Log($"Done! {_normProgress!.TitlesNormalized} titles decoded, " +
                $"{_normProgress.StarsDetected} stars detected, " +
                $"{_normProgress.TagsDetected} tags detected " +
                $"({count} videos processed).", "ok");
        }
        catch (OperationCanceledException)
        {
            Log("Normalization cancelled.", "warn");
        }
        catch (Exception ex)
        {
            Log($"Error: {ex.Message}", "error");
        }
        finally
        {
            _normRunning = false;
            _normCts?.Dispose();
            _normCts = null;
            refreshCts.Cancel();
            StateHasChanged();
        }
    }

    private async Task RefreshUiPeriodically(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(500, ct);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (ObjectDisposedException) { }
    }
}
