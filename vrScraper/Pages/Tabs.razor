@page "/tabs"

@using vrScraper.DB.Models
@using vrScraper.Services
@using vrScraper.Components
@using System.Text.Json

@inject ITabService TabService
@inject IVideoService VideoService
@inject IJSRuntime JSRuntime
@inject IScraperRegistry ScraperRegistry

@implements IDisposable

<div class="tabs-page">

    <!-- Top Toolbar -->
    <div class="tabs-toolbar">
        <h3 class="tabs-title">Manage Tabs</h3>
        <div class="tabs-toolbar-actions">
            <button class="vr-btn vr-btn-primary vr-btn-sm" @onclick="AddNewTab">
                <i class="icon-plus"></i> Add Tab
            </button>
            <button class="vr-btn vr-btn-success vr-btn-sm" @onclick="AddNewWatchlist">
                <i class="icon-bookmark"></i> Add Watchlist
            </button>
            <button class="vr-btn vr-btn-secondary vr-btn-sm" @onclick="SaveAllDirty" disabled="@(!HasAnyDirty)">
                <i class="icon-save"></i> Save All
            </button>
        </div>
    </div>

    <!-- Section 1: Default Tabs -->
    <div class="default-tabs-section">
        <h5 class="vr-section-title">
            <i class="icon-lock"></i> Default Tabs
        </h5>
        <div class="default-tabs-list">
            @foreach (var tab in DefaultTabs)
            {
                <div class="default-tab-row">
                    <span class="default-tab-name">
                        @if (tab.Name == "Recommended")
                        {
                            <i class="icon-sparkles recommended-icon"></i>
                        }
                        @tab.Name
                    </span>
                    <label class="vr-switch">
                        <input type="checkbox" checked="@tab.Active" @onchange="(e) => OnCheckboxChanged(e, tab)" />
                    </label>
                </div>
            }
        </div>
    </div>

    <!-- Section 2: Custom Tabs -->
    <div class="custom-tabs-section">
        <h5 class="vr-section-title">
            <i class="icon-layout-grid"></i> Custom Tabs
        </h5>

        @if (CustomTabs.Any())
        {
            <div class="tab-list" id="custom-tabs-sortable">
                @foreach (var tab in CustomTabs)
                {
                    <div class="tab-card" data-tab-id="@tab.Id" id="tab-@tab.Id">
                        <div class="tab-card-header">
                            <div class="drag-handle" title="Drag to reorder">
                                <i class="icon-grip-vertical"></i>
                            </div>

                            <div class="tab-card-title-area">
                                @if (!tab.IsEditing)
                                {
                                    <span class="tab-card-name">@tab.Name</span>
                                    <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => StartEditing(tab)" title="Edit name">
                                        <i class="icon-pencil"></i>
                                    </button>
                                }
                                else
                                {
                                    <input type="text" class="form-control form-control-sm tab-name-input" @bind="tab.Name" @oninput="() => MarkTabDirty(tab)" />
                                    <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => StopEditing(tab)" title="Confirm">
                                        <i class="icon-check"></i>
                                    </button>
                                    <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => CancelEditing(tab)" title="Cancel">
                                        <i class="icon-x"></i>
                                    </button>
                                }
                            </div>

                            <div class="tab-card-badges">
                                @{ var tagCount = tab.TagWhitelistList.Count(); }
                                @{ var exTagCount = tab.TagBlacklistList.Count(); }
                                @{ var actCount = tab.ActressWhitelistList.Count(); }
                                @{ var exActCount = tab.ActressBlacklistList.Count(); }
                                @{ var siteCount = tab.SiteFilterList.Count(); }

                                @if (tagCount > 0)
                                {
                                    <span class="filter-badge filter-badge--include">@tagCount Tags</span>
                                }
                                @if (exTagCount > 0)
                                {
                                    <span class="filter-badge filter-badge--exclude">@exTagCount Excl. Tags</span>
                                }
                                @if (actCount > 0)
                                {
                                    <span class="filter-badge filter-badge--include">@actCount Actresses</span>
                                }
                                @if (exActCount > 0)
                                {
                                    <span class="filter-badge filter-badge--exclude">@exActCount Excl. Actresses</span>
                                }
                                @if (siteCount > 0)
                                {
                                    <span class="filter-badge filter-badge--site">@siteCount Sites</span>
                                }
                            </div>

                            <div class="tab-card-actions">
                                <label class="vr-switch">
                                    <input type="checkbox" checked="@tab.Active" @onchange="(e) => OnCheckboxChanged(e, tab)" />
                                </label>
                                <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => ToggleFilterPanel(tab)" title="@(IsFilterExpanded(tab) ? "Collapse filters" : "Expand filters")">
                                    <i class="@(IsFilterExpanded(tab) ? "icon-chevron-up" : "icon-pencil")"></i>
                                </button>
                                <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm tab-delete-btn" @onclick="() => DeleteTab(tab.Id)" title="Delete tab">
                                    <i class="icon-trash-2"></i>
                                </button>
                            </div>
                        </div>

                        @if (IsFilterExpanded(tab))
                        {
                            <div class="tab-edit-panel">
                                <div class="filter-row">
                                    <label class="filter-label">Include Tags</label>
                                    <div class="filter-control">
                                        <MultiSelect IsMultiple="true" TItem="DbTag" Data="@AvailableTags"
                                                     TextField="@((item) => item.Name)"
                                                     ValueField="@((item) => item.Name)"
                                                     ShowSearch="true"
                                                     @bind-SelectedValues="tab.TagWhitelistList" />
                                    </div>
                                </div>
                                <div class="filter-row">
                                    <label class="filter-label">Exclude Tags</label>
                                    <div class="filter-control">
                                        <MultiSelect IsMultiple="true" TItem="DbTag" Data="@AvailableTags"
                                                     TextField="@((item) => item.Name)"
                                                     ValueField="@((item) => item.Name)"
                                                     ShowSearch="true"
                                                     @bind-SelectedValues="tab.TagBlacklistList" />
                                    </div>
                                </div>
                                <div class="filter-row">
                                    <label class="filter-label">Include Actresses</label>
                                    <div class="filter-control">
                                        <MultiSelect IsMultiple="true" TItem="DbStar" Data="@AvailableActresses"
                                                     TextField="@((item) => item.Name)"
                                                     ValueField="@((item) => item.Name)"
                                                     ShowSearch="true"
                                                     @bind-SelectedValues="tab.ActressWhitelistList" />
                                    </div>
                                </div>
                                <div class="filter-row">
                                    <label class="filter-label">Exclude Actresses</label>
                                    <div class="filter-control">
                                        <MultiSelect IsMultiple="true" TItem="DbStar" Data="@AvailableActresses"
                                                     TextField="@((item) => item.Name)"
                                                     ValueField="@((item) => item.Name)"
                                                     ShowSearch="true"
                                                     @bind-SelectedValues="tab.ActressBlacklistList" />
                                    </div>
                                </div>
                                <div class="filter-row">
                                    <label class="filter-label">Sites</label>
                                    <div class="filter-control">
                                        <MultiSelect IsMultiple="true" TItem="string" Data="@AvailableSites"
                                                     TextField="@((item) => item)"
                                                     ValueField="@((item) => item)"
                                                     @bind-SelectedValues="tab.SiteFilterList" />
                                    </div>
                                </div>
                                <div class="filter-actions">
                                    <button class="vr-btn vr-btn-success vr-btn-sm" @onclick="() => SaveTab(tab)" disabled="@(!tab.IsDirty)">
                                        <i class="icon-save"></i> Save
                                    </button>
                                </div>
                            </div>
                        }
                        else if (tab.IsDirty)
                        {
                            <div class="tab-card-dirty-bar">
                                <button class="vr-btn vr-btn-success vr-btn-sm" @onclick="() => SaveTab(tab)">
                                    <i class="icon-save"></i> Save
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="vr-empty-state">
                <i class="icon-layout-grid"></i>
                <p>No custom tabs yet. Click "Add Tab" to create one.</p>
            </div>
        }
    </div>

    <!-- Section 3: Watchlists -->
    <div class="watchlist-tabs-section">
        <h5 class="vr-section-title">
            <i class="icon-bookmark"></i> Watchlists
        </h5>

        @if (WatchlistTabs.Any())
        {
            <div class="tab-list" id="watchlist-tabs-sortable">
                @foreach (var tab in WatchlistTabs)
                {
                    <div class="tab-card tab-card--watchlist" data-tab-id="@tab.Id" id="tab-@tab.Id">
                        <div class="tab-card-header">
                            <div class="drag-handle" title="Drag to reorder">
                                <i class="icon-grip-vertical"></i>
                            </div>

                            <div class="tab-card-title-area">
                                @if (!tab.IsEditing)
                                {
                                    <i class="icon-bookmark watchlist-title-icon"></i>
                                    <span class="tab-card-name">@tab.Name</span>
                                    <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => StartEditing(tab)" title="Edit name">
                                        <i class="icon-pencil"></i>
                                    </button>
                                }
                                else
                                {
                                    <input type="text" class="form-control form-control-sm tab-name-input" @bind="tab.Name" @oninput="() => MarkTabDirty(tab)" />
                                    <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => StopEditing(tab)" title="Confirm">
                                        <i class="icon-check"></i>
                                    </button>
                                    <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm" @onclick="() => CancelEditing(tab)" title="Cancel">
                                        <i class="icon-x"></i>
                                    </button>
                                }
                            </div>

                            <div class="tab-card-badges">
                                @{ var videoCount = tab.VideoWhitelistList.Count(); }
                                <span class="filter-badge filter-badge--count">
                                    <i class="icon-film"></i> @videoCount Videos
                                </span>
                            </div>

                            <div class="tab-card-actions">
                                <label class="vr-switch">
                                    <input type="checkbox" checked="@tab.Active" @onchange="(e) => OnCheckboxChanged(e, tab)" />
                                </label>
                                <button class="vr-btn vr-btn-ghost vr-btn-icon vr-btn-sm tab-delete-btn" @onclick="() => DeleteTab(tab.Id)" title="Delete watchlist">
                                    <i class="icon-trash-2"></i>
                                </button>
                            </div>
                        </div>

                        @if (tab.IsDirty)
                        {
                            <div class="tab-card-dirty-bar">
                                <button class="vr-btn vr-btn-success vr-btn-sm" @onclick="() => SaveTab(tab)">
                                    <i class="icon-save"></i> Save
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="vr-empty-state">
                <i class="icon-bookmark"></i>
                <p>No watchlists yet. Click "Add Watchlist" to create one.</p>
            </div>
        }
    </div>

</div>

@code {

    private List<DbVrTab> AvailableTabs { get; set; } = new();
    private List<DbTag> AvailableTags { get; set; } = new();
    private List<DbStar> AvailableActresses { get; set; } = new();
    private List<string> AvailableSites { get; set; } = new();
    private Dictionary<long, string> _originalNames = new();
    private HashSet<long> _expandedTabs = new();
    private DotNetObjectReference<Tabs>? _dotNetRef;

    private IEnumerable<DbVrTab> DefaultTabs => AvailableTabs
        .Where(t => t.Type == "DEFAULT")
        .OrderBy(t => t.Order);

    private IEnumerable<DbVrTab> CustomTabs => AvailableTabs
        .Where(t => t.Type == "CUSTOM")
        .OrderBy(t => t.Order);

    private IEnumerable<DbVrTab> WatchlistTabs => AvailableTabs
        .Where(t => t.Type == "WATCHLIST")
        .OrderBy(t => t.Order);

    private bool HasAnyDirty => AvailableTabs.Any(t => t.IsDirty);

    protected override async Task OnInitializedAsync()
    {
        await LoadTabs();
        await LoadTags();
        await LoadActresses();
        AvailableSites = ScraperRegistry.GetEnabledSiteNames().ToList();
    }

    private bool _sortableNeedsInit = true;
    private long? _scrollToTabId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_sortableNeedsInit && _dotNetRef != null)
        {
            _sortableNeedsInit = false;
            await JSRuntime.InvokeVoidAsync("tabSortable.init", "custom-tabs-sortable", _dotNetRef);
            await JSRuntime.InvokeVoidAsync("tabSortable.init", "watchlist-tabs-sortable", _dotNetRef);
        }

        if (_scrollToTabId.HasValue)
        {
            var id = _scrollToTabId.Value;
            _scrollToTabId = null;
            await JSRuntime.InvokeVoidAsync("eval",
                $"document.getElementById('tab-{id}')?.scrollIntoView({{behavior:'smooth',block:'center'}})");
        }
    }

    [JSInvokable]
    public async Task OnTabOrderChanged(int[] newOrder)
    {
        for (int i = 0; i < newOrder.Length; i++)
        {
            var tab = AvailableTabs.FirstOrDefault(t => t.Id == newOrder[i]);
            if (tab != null && tab.Type != "DEFAULT")
            {
                tab.Order = i;
                tab.IsDirty = true;
            }
        }
        await SaveAllDirty();
        StateHasChanged();
    }

    private async Task LoadTabs()
    {
        AvailableTabs = await this.TabService.GetAllTabs();
        _sortableNeedsInit = true;
    }

    private async Task LoadTags()
    {
        AvailableTags = (await VideoService.GetTagInfos()).Select(x => x.Tag).ToList();
    }

    private async Task LoadActresses()
    {
        AvailableActresses = (await VideoService.GetActorInfos()).Select(x => x.Star).ToList();
    }

    private async Task AddNewTab()
    {
        var newTab = new DbVrTab
            {
                Name = "New Tab",
                Type = "CUSTOM",
                Active = true,
                Order = AvailableTabs.Count + 1,
                TagWhitelist = "[]",
                ActressWhitelist = "[]",
                TagBlacklist = "[]",
                ActressBlacklist = "[]",
                VideoWhitelist = "[]",
                VideoBlacklist = "[]",
                SiteFilter = "[]"
            };

        await TabService.AddTab(newTab);
        _scrollToTabId = newTab.Id;
        await LoadTabs();
    }

    private async Task AddNewWatchlist()
    {
        var newTab = new DbVrTab
            {
                Name = "New Watchlist",
                Type = "WATCHLIST",
                Active = true,
                Order = AvailableTabs.Count + 1,
                TagWhitelist = "[]",
                ActressWhitelist = "[]",
                TagBlacklist = "[]",
                ActressBlacklist = "[]",
                VideoWhitelist = "[]",
                VideoBlacklist = "[]",
                SiteFilter = "[]"
            };

        await TabService.AddTab(newTab);
        _scrollToTabId = newTab.Id;
        await LoadTabs();
    }

    private async Task DeleteTab(long id)
    {
        var tabToDelete = AvailableTabs.FirstOrDefault(t => t.Id == id);

        if (tabToDelete != null && tabToDelete.Type != "DEFAULT")
        {
            bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this tab?");
            if (!confirmed) return;

            _expandedTabs.Remove(id);
            await TabService.DeleteTab(id);
            await LoadTabs();
        }
    }

    private async Task SaveTab(DbVrTab tab)
    {
        await TabService.UpdateTab(tab);
        tab.IsDirty = false;
        tab.IsEditing = false;
        // Don't call LoadTabs() — the tab is already updated in the singleton cache
    }

    private async Task SaveAllDirty()
    {
        foreach (var tab in AvailableTabs.Where(t => t.IsDirty))
        {
            await TabService.UpdateTab(tab);
            tab.IsDirty = false;
            tab.IsEditing = false;
        }
    }

    private bool IsDefaultTab(DbVrTab tab)
    {
        return tab.Type == "DEFAULT";
    }

    private void MarkTabDirty(DbVrTab tab)
    {
        tab.IsDirty = true;
    }

    private void OnInputChanged(ChangeEventArgs e, DbVrTab tab, string propertyName)
    {
        var value = e.Value?.ToString();

        switch (propertyName)
        {
            case nameof(tab.Order):
                if (int.TryParse(value, out var order))
                {
                    tab.Order = order;
                }
                break;
        }

        MarkTabDirty(tab);
    }

    private void OnCheckboxChanged(ChangeEventArgs e, DbVrTab tab)
    {
        if (bool.TryParse(e.Value!.ToString(), out var isChecked))
        {
            tab.Active = isChecked;
            MarkTabDirty(tab);
        }
    }

    private void StartEditing(DbVrTab tab)
    {
        _originalNames[tab.Id] = tab.Name;
        tab.IsEditing = true;
    }

    private void StopEditing(DbVrTab tab)
    {
        _originalNames.Remove(tab.Id);
        tab.IsEditing = false;
        MarkTabDirty(tab);
    }

    private void CancelEditing(DbVrTab tab)
    {
        if (_originalNames.TryGetValue(tab.Id, out var originalName))
        {
            tab.Name = originalName;
            _originalNames.Remove(tab.Id);
        }
        tab.IsEditing = false;
    }

    private void ToggleFilterPanel(DbVrTab tab)
    {
        if (_expandedTabs.Contains(tab.Id))
        {
            _expandedTabs.Remove(tab.Id);
        }
        else
        {
            _expandedTabs.Add(tab.Id);
        }
    }

    private bool IsFilterExpanded(DbVrTab tab)
    {
        return _expandedTabs.Contains(tab.Id);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
